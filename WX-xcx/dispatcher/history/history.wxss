.history-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

.filter-bar {
  background-color: #ffffff;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #eeeeee;
  position: sticky;
  top: 0;
  z-index: 5;
}

.filter-scroll {
  white-space: nowrap;
  padding: 0 24rpx;
}

.filter-item {
  display: inline-block;
  padding: 10rpx 24rpx;
  margin-right: 16rpx;
  font-size: 24rpx;
  color: #666666;
  background-color: #f5f5f5;
  border-radius: 32rpx;
  border: 2rpx solid transparent;
}

.filter-item.filter-active {
  color: #e94560;
  background-color: rgba(233, 69, 96, 0.08);
  border-color: #e94560;
}

.history-list {
  padding: 16rpx 24rpx;
}

.record-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
  margin-bottom: 16rpx;
}

.dispatch-id {
  font-size: 24rpx;
  color: #999999;
}

.dispatch-status {
  font-size: 24rpx;
  font-weight: 500;
}

.record-body {
  margin-bottom: 0;
}

.record-row {
  display: flex;
  margin-bottom: 10rpx;
  font-size: 26rpx;
}

.record-row:last-child {
  margin-bottom: 0;
}

.row-label {
  color: #999999;
  flex-shrink: 0;
}

.row-value {
  color: #333333;
}

.record-footer {
  padding-top: 16rpx;
  margin-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
  display: flex;
}

.remark-label {
  font-size: 24rpx;
  color: #999999;
  flex-shrink: 0;
}

.remark-text {
  font-size: 24rpx;
  color: #666666;
  flex: 1;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-state-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-state-text {
  font-size: 28rpx;
  color: #999999;
}

.loading-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.loading-more {
  text-align: center;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: #999999;
}

.no-more {
  text-align: center;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: #cccccc;
}