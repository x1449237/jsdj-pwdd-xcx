.message-item {
  padding: var(--spacing-sm) var(--spacing-md);
}

/* 系统消息 */
.message-system {
  display: flex;
  justify-content: center;
  padding: var(--spacing-sm) 0;
}

.system-text {
  background-color: rgba(0, 0, 0, 0.08);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

/* 自己发送的消息 */
.message-self {
  display: flex;
  justify-content: flex-end;
  align-items: flex-start;
}

.message-self .message-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-left: var(--spacing-sm);
  flex-shrink: 0;
}

/* 对方发送的消息 */
.message-other {
  display: flex;
  justify-content: flex-start;
  align-items: flex-start;
}

.message-other .message-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: var(--spacing-sm);
  flex-shrink: 0;
}

/* 消息气泡 */
.message-bubble-wrapper {
  max-width: 70%;
  display: flex;
  flex-direction: column;
}

.message-bubble {
  padding: var(--spacing-sm) var(--spacing-md);
  border-radius: var(--border-radius-md);
  word-break: break-all;
  position: relative;
}

.bubble-self {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  color: var(--color-text-white);
  border-top-right-radius: 4rpx;
}

.bubble-other {
  background-color: var(--color-bg-white);
  color: var(--color-text-primary);
  border-top-left-radius: 4rpx;
  box-shadow: var(--shadow-sm);
}

.bubble-text {
  font-size: var(--font-size-md);
  line-height: 1.6;
}

/* 语音消息 */
.bubble-voice {
  display: flex;
  align-items: center;
  min-width: 160rpx;
  padding: 4rpx 0;
}

.bubble-self .bubble-voice {
  flex-direction: row-reverse;
}

.voice-icon {
  font-size: var(--font-size-lg);
  margin: 0 var(--spacing-xs);
}

.voice-duration {
  font-size: var(--font-size-sm);
  margin: 0 var(--spacing-xs);
}

.voice-waves {
  display: flex;
  align-items: center;
  gap: 3rpx;
  height: 32rpx;
}

.voice-wave {
  width: 4rpx;
  background-color: currentColor;
  border-radius: 2rpx;
  opacity: 0.6;
}

.voice-wave:nth-child(1) { height: 12rpx; }
.voice-wave:nth-child(2) { height: 24rpx; }
.voice-wave:nth-child(3) { height: 16rpx; }
.voice-wave:nth-child(4) { height: 28rpx; }

/* 图片消息 */
.bubble-image {
  width: 320rpx;
  height: 320rpx;
  border-radius: var(--border-radius-sm);
}

/* 消息元信息 */
.message-meta {
  display: flex;
  align-items: center;
  margin-top: 4rpx;
}

.message-self .message-meta {
  justify-content: flex-end;
}

.message-other .message-meta {
  justify-content: flex-start;
}

.meta-read {
  margin-right: var(--spacing-xs);
}

.meta-time {
  font-size: 20rpx;
}