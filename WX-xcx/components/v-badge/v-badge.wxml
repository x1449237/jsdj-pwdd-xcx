<view class="v-badge-wrapper">
  <!-- V标样式（圆角矩形） -->
  <view class="v-badge {{badgeClass}}" wx:if="{{!isUpMaster}}">
    <text class="v-badge-text">V</text>
  </view>
  
  <!-- UP主徽标样式（圆形） -->
  <view class="up-badge {{badgeClass}}" wx:else>
    <text class="up-badge-text">{{badgeLabel}}</text>
  </view>
</view>