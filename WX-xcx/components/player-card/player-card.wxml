<view class="player-card {{extraClass}}" bindtap="onTap">
  <view class="player-main">
    <!-- 头像 -->
    <view class="avatar-wrapper">
      <image class="player-avatar" src="{{player.avatar}}" mode="aspectFill"></image>
      <view class="online-dot {{player.is_online ? 'online' : 'offline'}}"></view>
    </view>

    <!-- 信息区 -->
    <view class="player-info">
      <view class="info-top">
        <text class="player-nickname text-md font-bold">{{player.nickname}}</text>
        <view class="gender-icon" wx:if="{{player.gender === 1}}">
          <text class="gender-male">♂</text>
        </view>
        <view class="gender-icon" wx:if="{{player.gender === 2}}">
          <text class="gender-female">♀</text>
        </view>
      </view>
      <view class="info-tags">
        <text class="tag tag-gold">{{player.rank}}</text>
        <text class="tag tag-primary" wx:if="{{player.specialty}}">{{player.specialty}}</text>
      </view>
      <view class="info-meta">
        <text class="meta-text text-sm text-secondary">
          好评率 <text class="text-success">{{player.good_rate}}%</text>
        </text>
        <text class="meta-text text-sm text-tip ml-md">
          已接单 <text>{{player.order_count}}</text> 单
        </text>
      </view>
    </view>

    <!-- 价格区 -->
    <view class="player-price">
      <text class="price-symbol text-sm text-primary">¥</text>
      <text class="price-value text-xl text-primary font-bold">{{player.price}}</text>
      <text class="price-unit text-xs text-tip">/局</text>
    </view>
  </view>

  <!-- 在线状态 -->
  <view class="player-status">
    <text class="status-text text-xs {{player.is_online ? 'text-success' : 'text-tip'}}">
      {{player.is_online ? '在线' : '离线'}}
    </text>
  </view>
</view>