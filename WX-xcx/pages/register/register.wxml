<view class="register-page">
  <view class="register-header">
    <text class="title">完善信息</text>
    <text class="subtitle">完善以下信息，开始您的接单之旅</text>
  </view>

  <view class="register-form">
    <view class="avatar-section">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image
          class="avatar-img"
          src="{{avatarUrl || '/assets/images/default-avatar.png'}}"
          mode="aspectFill"
        ></image>
        <view class="avatar-tip">
          <text>点击选择头像</text>
        </view>
      </button>
    </view>

    <view class="form-group">
      <view class="form-label">昵称</view>
      <input
        class="form-input"
        type="nickname"
        placeholder="请输入昵称"
        value="{{nickname}}"
        bindinput="onNicknameInput"
        maxlength="20"
      />
    </view>

    <view class="form-group">
      <view class="form-label">邀请码（选填）</view>
      <input
        class="form-input"
        placeholder="请输入邀请码"
        value="{{inviteCode}}"
        bindinput="onInviteCodeInput"
        maxlength="10"
      />
      <view class="form-tip">输入打手/分销商/派单员的邀请码</view>
    </view>

    <view class="form-group">
      <view class="form-label">选择角色</view>
      <view class="role-options">
        <view
          class="role-item {{role === 'user' ? 'active' : ''}}"
          bindtap="onSelectRole"
          data-role="user"
        >
          <text class="role-icon">👤</text>
          <text class="role-name">普通用户</text>
          <text class="role-desc">下单找大神</text>
        </view>
        <view
          class="role-item {{role === 'player' ? 'active' : ''}}"
          bindtap="onSelectRole"
          data-role="player"
        >
          <text class="role-icon">🎮</text>
          <text class="role-name">打手</text>
          <text class="role-desc">接单赚钱</text>
        </view>
      </view>
    </view>

    <view class="form-group">
      <view class="form-label">手机号</view>
      <view class="phone-display">
        <text>{{phone}}</text>
      </view>
    </view>
  </view>

  <view class="register-footer">
    <button
      class="btn btn-primary btn-block submit-btn"
      loading="{{submitting}}"
      disabled="{{!canSubmit}}"
      bindtap="onSubmit"
    >
      完成注册
    </button>
    <button class="btn btn-ghost btn-block skip-btn" bindtap="onSkip">
      跳过，稍后完善
    </button>
  </view>
</view>