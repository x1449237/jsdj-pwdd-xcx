.register-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 200rpx;
}

.register-header {
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

.register-form {
  padding: 0 32rpx;
  margin-top: -20rpx;
}

.avatar-section {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.avatar-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: none;
  padding: 0;
  border: none;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  background-color: #f0f0f0;
}

.avatar-tip {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999999;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.form-tip {
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}

.role-options {
  display: flex;
  gap: 20rpx;
}

.role-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 20rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  border: 2rpx solid #eeeeee;
  transition: all 0.3s;
}

.role-item.active {
  border-color: #e94560;
  background-color: rgba(233, 69, 96, 0.05);
}

.role-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.role-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.role-desc {
  font-size: 22rpx;
  color: #999999;
}

.phone-display {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #999999;
  box-sizing: border-box;
}

.register-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.submit-btn {
  margin-bottom: 16rpx;
}

.skip-btn {
  color: #999999;
  font-size: 26rpx;
}