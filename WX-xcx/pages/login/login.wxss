.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 0 60rpx;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(233, 69, 96, 0.3);
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

.login-body {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-form {
  width: 100%;
  margin-bottom: 40rpx;
}

.wechat-login-btn {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #07c160, #06ad56);
  border-radius: 48rpx;
  border: none;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
}

.wechat-login-btn::after {
  border: none;
}

.wechat-login-btn[disabled] {
  opacity: 0.5;
}

.wechat-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}

.agreement-wrapper {
  width: 100%;
  margin-bottom: 40rpx;
}

.agreement-check {
  display: flex;
  align-items: flex-start;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 50%;
  margin-right: 12rpx;
  margin-top: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.checkbox.checked {
  background-color: #07c160;
  border-color: #07c160;
}

.check-icon {
  width: 24rpx;
  height: 24rpx;
}

.agreement-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.8;
}

.link {
  color: #e94560;
}

.other-login {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.other-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-bottom: 24rpx;
  position: relative;
}

.other-text::before,
.other-text::after {
  content: '';
  position: absolute;
  top: 50%;
  width: 60rpx;
  height: 1rpx;
  background-color: rgba(255, 255, 255, 0.2);
}

.other-text::before {
  right: 120%;
}

.other-text::after {
  left: 120%;
}

.other-icons {
  display: flex;
}

.other-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 30rpx;
}

.other-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.other-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

.login-footer {
  position: fixed;
  bottom: 60rpx;
}

.footer-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* 协议弹窗 */
.agreement-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
}

.modal-content {
  position: relative;
  width: 620rpx;
  max-height: 80vh;
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  padding: 36rpx 32rpx 20rpx;
  text-align: center;
  border-bottom: 1rpx solid #eeeeee;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

.modal-body {
  flex: 1;
  overflow: hidden;
}

.agreement-scroll {
  height: 500rpx;
  padding: 24rpx 32rpx;
}

.agreement-content {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
  white-space: pre-wrap;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #eeeeee;
}

.modal-btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  font-size: 30rpx;
  border: none;
  border-radius: 0;
  background: none;
}

.modal-btn::after {
  border: none;
}

.cancel-btn {
  color: #999999;
  border-right: 1rpx solid #eeeeee;
}

.confirm-btn {
  color: #e94560;
  font-weight: bold;
}