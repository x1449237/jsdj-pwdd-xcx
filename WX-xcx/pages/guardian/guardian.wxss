.guardian-page {
  min-height: 100vh;
  background-color: var(--color-bg);
  padding-bottom: var(--spacing-xl);
}

.page-header {
  padding: var(--spacing-xl) var(--spacing-lg) var(--spacing-md);
  text-align: center;
}

.page-title {
  display: block;
  font-size: var(--font-size-xxl);
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-sm);
}

.page-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-tip);
}

.card-title {
  font-size: var(--font-size-lg);
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-md);
  padding-bottom: var(--spacing-sm);
  border-bottom: 1rpx solid var(--color-border);
}

/* 活体检测 */
.liveness-area {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.liveness-frame {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: var(--spacing-md) 0;
}

.frame-circle {
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  border: 4rpx dashed var(--color-border);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: var(--color-bg);
  overflow: hidden;
  transition: border-color 0.3s;
}

.liveness-frame.scanning .frame-circle {
  border-color: var(--color-primary);
  border-style: solid;
  animation: frame-pulse 1.5s ease-in-out infinite;
}

.liveness-frame.success .frame-circle {
  border-color: var(--color-success);
  border-style: solid;
  background-color: rgba(7, 193, 96, 0.05);
}

.liveness-frame.fail .frame-circle {
  border-color: var(--color-danger);
  border-style: solid;
  background-color: rgba(233, 69, 96, 0.05);
}

@keyframes frame-pulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(233, 69, 96, 0.3); }
  50% { box-shadow: 0 0 0 20rpx rgba(233, 69, 96, 0); }
}

.frame-icon {
  width: 100rpx;
  height: 100rpx;
  opacity: 0.4;
}

.frame-hint {
  margin-top: var(--spacing-sm);
}

.frame-hint text {
  font-size: var(--font-size-sm);
  color: var(--color-text-tip);
}

.frame-scanning {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.scanning-wave {
  width: 80rpx;
  height: 4rpx;
  background-color: var(--color-primary);
  border-radius: 2rpx;
  animation: wave-move 1s ease-in-out infinite;
  margin-bottom: var(--spacing-sm);
}

@keyframes wave-move {
  0%, 100% { transform: scaleX(1); opacity: 0.5; }
  50% { transform: scaleX(2); opacity: 1; }
}

.scanning-text {
  font-size: var(--font-size-md);
  color: var(--color-primary);
}

.frame-result {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.result-icon {
  font-size: 56rpx;
  font-weight: bold;
}

.frame-result.success .result-icon {
  color: var(--color-success);
}

.frame-result.fail .result-icon {
  color: var(--color-danger);
}

.result-text {
  font-size: var(--font-size-md);
  margin-top: var(--spacing-xs);
  font-weight: 500;
}

.frame-result.success .result-text {
  color: var(--color-success);
}

.frame-result.fail .result-text {
  color: var(--color-danger);
}

.result-reason {
  font-size: var(--font-size-xs);
  color: var(--color-text-tip);
  margin-top: var(--spacing-xs);
  text-align: center;
}

.liveness-actions {
  width: 100%;
  margin-top: var(--spacing-md);
}

/* 免责声明 */
.disclaimer-content {
  margin-bottom: var(--spacing-md);
}

.disclaimer-scroll {
  height: 260rpx;
  background-color: var(--color-bg);
  border-radius: var(--border-radius-sm);
  padding: var(--spacing-md);
  box-sizing: border-box;
}

.disclaimer-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: 1.8;
  white-space: pre-wrap;
}

.disclaimer-agree {
  padding-top: var(--spacing-sm);
}

.agreement-check {
  display: flex;
  align-items: center;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacing-sm);
  flex-shrink: 0;
}

.checkbox.checked {
  background-color: var(--color-primary);
  border-color: var(--color-primary);
}

.check-icon {
  font-size: var(--font-size-xs);
  color: var(--color-text-white);
}

.agreement-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

/* CA电子签名 */
.signature-area {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.signature-canvas-wrapper {
  position: relative;
  width: 100%;
  height: 320rpx;
  background-color: var(--color-bg);
  border: 2rpx solid var(--color-border);
  border-radius: var(--border-radius-sm);
  overflow: hidden;
}

.signature-canvas {
  width: 100%;
  height: 100%;
}

.signature-hint {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
}

.signature-hint text {
  font-size: var(--font-size-md);
  color: var(--color-text-tip);
}

.signature-actions {
  display: flex;
  justify-content: flex-end;
  width: 100%;
  margin-top: var(--spacing-sm);
}

/* 提交区域 */
.submit-wrapper {
  padding: var(--spacing-lg) var(--spacing-md);
}