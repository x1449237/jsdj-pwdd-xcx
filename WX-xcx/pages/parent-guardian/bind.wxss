.bind-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 30rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  padding: 40rpx 0;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #303133;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #909399;
}

.form-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: #606266;
  margin-bottom: 16rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  background: #f5f7fa;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #303133;
  box-sizing: border-box;
}

.code-input-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.code-input {
  flex: 1;
}

.send-code-btn {
  width: 220rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  background: #409eff;
  color: #ffffff;
  border-radius: 8rpx;
  padding: 0;
  margin: 0;
}

.send-code-btn.disabled {
  background: #a0cfff;
}

.tips-card {
  background: #ecf5ff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #409eff;
  margin-bottom: 16rpx;
}

.tips-item {
  font-size: 24rpx;
  color: #606266;
  line-height: 1.8;
}

.bind-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: none;
}

.bind-btn::after {
  border: none;
}
