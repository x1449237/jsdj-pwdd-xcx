.report-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 20rpx;
  box-sizing: border-box;
}

.month-selector {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 20rpx;
}

.picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-label {
  font-size: 28rpx;
  color: #606266;
}

.picker-value {
  font-size: 28rpx;
  color: #303133;
  font-weight: 500;
}

.picker-arrow {
  font-size: 32rpx;
  color: #c0c4cc;
  margin-left: 10rpx;
}

.summary-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  color: #ffffff;
  text-align: center;
  margin-bottom: 20rpx;
}

.summary-title {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 16rpx;
}

.summary-amount {
  font-size: 56rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.summary-count {
  font-size: 26rpx;
  opacity: 0.85;
}

.orders-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #303133;
  margin-bottom: 24rpx;
}

.empty-orders {
  padding: 60rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #909399;
}

.order-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.order-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.order-sn {
  font-size: 26rpx;
  color: #909399;
}

.order-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.status-1 {
  background: #fdf6ec;
  color: #e6a23c;
}

.status-2 {
  background: #ecf5ff;
  color: #409eff;
}

.status-5 {
  background: #f0f9eb;
  color: #67c23a;
}

.order-body {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.order-game {
  font-size: 28rpx;
  color: #303133;
  flex: 1;
}

.order-amount {
  font-size: 30rpx;
  font-weight: 600;
  color: #f56c6c;
}

.order-footer {
  display: flex;
  align-items: center;
}

.order-time {
  font-size: 24rpx;
  color: #c0c4cc;
}
