.home-page {
  min-height: 100vh;
  background: #f5f7fa;
}

.header-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 30rpx 80rpx;
  color: #ffffff;
}

.header-title {
  font-size: 44rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.header-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

.content {
  margin-top: -40rpx;
  padding: 0 30rpx 40rpx;
}

.empty-card {
  background: #ffffff;
  margin: 30rpx;
  border-radius: 16rpx;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #909399;
  margin-bottom: 40rpx;
}

.bind-btn {
  width: 400rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: none;
}

.bind-btn::after {
  border: none;
}

.selector-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.selector-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.selector-label {
  font-size: 28rpx;
  color: #606266;
}

.selector-value {
  font-size: 30rpx;
  color: #303133;
  font-weight: 500;
  display: flex;
  align-items: center;
}

.selector-arrow {
  font-size: 32rpx;
  color: #c0c4cc;
  margin-left: 8rpx;
}

.consume-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.consume-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.consume-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #303133;
}

.consume-more {
  font-size: 26rpx;
  color: #409eff;
}

.consume-amount {
  font-size: 48rpx;
  font-weight: 600;
  color: #f56c6c;
  margin-bottom: 20rpx;
}

.consume-limit {
  font-size: 26rpx;
  font-weight: normal;
  color: #909399;
}

.consume-progress {
  height: 12rpx;
  background: #ebeef5;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #67c23a, #f56c6c);
  border-radius: 6rpx;
  transition: width 0.3s;
}

.consume-limit-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
  color: #606266;
}

.edit-text {
  color: #409eff;
}

.setting-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #303133;
  margin-bottom: 24rpx;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.setting-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.setting-info {
  flex: 1;
}

.setting-name {
  font-size: 28rpx;
  color: #303133;
  margin-bottom: 8rpx;
}

.freeze-name {
  color: #f56c6c;
}

.setting-desc {
  font-size: 24rpx;
  color: #909399;
}

.menu-card {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #303133;
}

.menu-arrow {
  font-size: 32rpx;
  color: #c0c4cc;
}

.unbind-row {
  padding: 20rpx 0;
}

.unbind-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #ffffff;
  color: #f56c6c;
  font-size: 28rpx;
  border-radius: 12rpx;
  border: none;
}

.unbind-btn::after {
  border: none;
}
