.appeal-detail-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 状态栏 */
.status-bar {
  padding: 32rpx;
}

.status-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 24rpx;
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
  border-radius: 16rpx;
}

.status-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

.status-value {
  font-size: 32rpx;
  font-weight: bold;
}

/* 信息区块 */
.info-section {
  margin: 0 32rpx 16rpx;
  padding: 24rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  margin-bottom: 20rpx;
}

.title-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.info-list {
  display: flex;
  flex-direction: column;
}

.info-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #999999;
}

.info-value {
  font-size: 26rpx;
  color: #333333;
  text-align: right;
}

.desc-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
}

/* 证据 */
.evidence-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.video-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  background-color: #f5f5f5;
  border-radius: 12rpx;
}

.video-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.video-text {
  font-size: 26rpx;
  color: #333333;
  margin-bottom: 4rpx;
}

.video-tip {
  font-size: 22rpx;
  color: #999999;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.evidence-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
}

/* 处理结果 */
.result-content {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.8;
  padding: 16rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
}

/* 沟通记录 */
.chat-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.chat-item {
  padding: 16rpx;
  background-color: #f8f9fa;
  border-radius: 8rpx;
}

.chat-user {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.chat-user-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
}

.chat-time {
  font-size: 22rpx;
  color: #cccccc;
}

.chat-content {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

/* 回复 */
.reply-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: flex-end;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.reply-input-wrapper {
  flex: 1;
  margin-right: 16rpx;
}

.reply-input {
  width: 100%;
  min-height: 72rpx;
  max-height: 160rpx;
  padding: 12rpx 16rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333333;
  box-sizing: border-box;
}

.reply-btn {
  height: 72rpx;
  padding: 0 32rpx;
  font-size: 26rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}