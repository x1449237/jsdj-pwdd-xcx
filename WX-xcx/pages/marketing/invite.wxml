<view class="invite-page">
  <!-- 未登录提示 -->
  <view class="empty-tip" wx:if="{{!isLogin}}">
    <text class="empty-text">请先登录查看邀请信息</text>
    <button class="login-btn" bindtap="onLogin">去登录</button>
  </view>

  <block wx:else>
    <!-- 顶部邀请卡片 -->
    <view class="invite-card">
      <view class="card-title">邀请好友 一起赚</view>
      <view class="card-subtitle">邀请好友注册并完成首单，双方均有奖励</view>

      <!-- 统计数据 -->
      <view class="stats-row">
        <view class="stats-item">
          <text class="stats-num">{{stats.invite_count}}</text>
          <text class="stats-label">邀请人数</text>
        </view>
        <view class="stats-divider"></view>
        <view class="stats-item">
          <text class="stats-num">¥{{stats.reward_amount}}</text>
          <text class="stats-label">累计奖励</text>
        </view>
      </view>

      <!-- 邀请码 -->
      <view class="code-section">
        <view class="code-label">我的邀请码</view>
        <view class="code-row">
          <text class="code-value">{{inviteCode}}</text>
          <view class="copy-btn" bindtap="onCopyCode">复制</view>
        </view>
      </view>
    </view>

    <!-- 二维码分享 -->
    <view class="qr-section">
      <view class="section-title">分享二维码</view>
      <view class="qr-card">
        <image
          class="qr-image"
          src="{{inviteQrCode || '/assets/images/qr-placeholder.png'}}"
          mode="aspectFit"
        ></image>
        <view class="qr-tip">扫一扫 立即注册</view>
      </view>
      <button class="share-btn" open-type="share">
        微信分享给好友
      </button>
    </view>

    <!-- 邀请奖励记录 -->
    <view class="reward-section">
      <view class="section-header">
        <text class="section-title">奖励记录</text>
        <text class="rule-link" bindtap="onRewardRule">规则说明</text>
      </view>

      <view class="reward-list" wx:if="{{rewardList.length > 0}}">
        <view class="reward-item" wx:for="{{rewardList}}" wx:key="id">
          <view class="reward-info">
            <text class="reward-desc">{{item.reward_type === 'balance' ? '余额奖励' : '优惠券奖励'}}</text>
            <text class="reward-time">{{item.create_time}}</text>
          </view>
          <view class="reward-value">
            <text wx:if="{{item.reward_type === 'balance'}}">+¥{{item.reward_value}}</text>
            <text wx:else>优惠券</text>
          </view>
        </view>
      </view>
      <view class="empty-records" wx:else>
        <text>暂无奖励记录</text>
      </view>
    </view>
  </block>
</view>
