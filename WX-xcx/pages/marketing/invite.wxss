.invite-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

.invite-card {
  background: linear-gradient(135deg, #e94560 0%, #ff6b6b 100%);
  margin: 20rpx 30rpx;
  padding: 50rpx 40rpx;
  border-radius: 20rpx;
  color: #fff;
}

.card-title {
  font-size: 40rpx;
  font-weight: bold;
  text-align: center;
}

.card-subtitle {
  font-size: 26rpx;
  text-align: center;
  margin-top: 12rpx;
  opacity: 0.9;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 50rpx 0;
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-num {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
}

.stats-label {
  display: block;
  font-size: 24rpx;
  margin-top: 8rpx;
  opacity: 0.9;
}

.stats-divider {
  width: 2rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.3);
}

.code-section {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 12rpx;
  padding: 30rpx;
}

.code-label {
  font-size: 24rpx;
  opacity: 0.9;
  margin-bottom: 16rpx;
}

.code-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.code-value {
  font-size: 48rpx;
  font-weight: bold;
  letter-spacing: 8rpx;
}

.copy-btn {
  padding: 12rpx 30rpx;
  background: #fff;
  color: #e94560;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.qr-section {
  background: #fff;
  margin: 20rpx 30rpx;
  padding: 40rpx 30rpx;
  border-radius: 16rpx;
  text-align: center;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
  text-align: left;
}

.qr-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.qr-image {
  width: 300rpx;
  height: 300rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.qr-tip {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #666;
}

.share-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #e94560 0%, #ff6b6b 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  padding: 0;
}

.share-btn::after {
  border: none;
}

.reward-section {
  background: #fff;
  margin: 20rpx 30rpx;
  padding: 30rpx;
  border-radius: 16rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-header .section-title {
  margin-bottom: 0;
}

.rule-link {
  font-size: 26rpx;
  color: #e94560;
}

.reward-list {
  max-height: 500rpx;
  overflow-y: auto;
}

.reward-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.reward-item:last-child {
  border-bottom: none;
}

.reward-info {
  display: flex;
  flex-direction: column;
}

.reward-desc {
  font-size: 28rpx;
  color: #333;
}

.reward-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.reward-value {
  font-size: 30rpx;
  font-weight: bold;
  color: #e94560;
}

.empty-records {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 60rpx 0;
}

.empty-tip {
  padding: 200rpx 0;
  text-align: center;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}

.login-btn {
  margin-top: 30rpx;
  width: 200rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: #e94560;
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
}
