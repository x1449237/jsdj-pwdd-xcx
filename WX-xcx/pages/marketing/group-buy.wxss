.group-buy-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

.tab-bar {
  display: flex;
  background: #fff;
  padding: 0 30rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #e94560;
  font-weight: 600;
}

.tab-line {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: #e94560;
  border-radius: 3rpx;
}

.activity-list,
.group-list {
  padding: 20rpx 30rpx;
}

.activity-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.activity-info {
  flex: 1;
}

.activity-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.activity-price {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.group-price {
  font-size: 40rpx;
  font-weight: bold;
  color: #e94560;
}

.original-price {
  font-size: 26rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 16rpx;
}

.activity-meta {
  font-size: 24rpx;
  color: #999;
}

.activity-meta text {
  margin-right: 8rpx;
}

.activity-action {
  margin-left: 20rpx;
}

.join-btn {
  width: 160rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: linear-gradient(135deg, #e94560 0%, #ff6b6b 100%);
  color: #fff;
  border-radius: 36rpx;
  font-size: 26rpx;
  padding: 0;
}

.join-btn::after {
  border: none;
}

.group-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.group-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.group-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.group-status.pending {
  background: #fff5f7;
  color: #e94560;
}

.group-status.success {
  background: #ecfdf5;
  color: #10b981;
}

.group-status.failed {
  background: #f3f4f6;
  color: #9ca3af;
}

.group-count {
  font-size: 26rpx;
  color: #666;
}

.group-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.group-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.group-footer .group-price {
  font-size: 32rpx;
}

.group-arrow {
  font-size: 26rpx;
  color: #e94560;
}

.empty-tip {
  padding: 100rpx 0;
  text-align: center;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}

.load-more {
  text-align: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 24rpx;
}
