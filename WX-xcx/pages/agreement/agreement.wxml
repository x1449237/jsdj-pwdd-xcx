<view class="agreement-page">
  <view class="agreement-tabs">
    <view
      class="tab-item {{currentTab === 'agreement' ? 'active' : ''}}"
      bindtap="onSwitchTab"
      data-tab="agreement"
    >
      <text>协议</text>
    </view>
    <view
      class="tab-item {{currentTab === 'policy' ? 'active' : ''}}"
      bindtap="onSwitchTab"
      data-tab="policy"
    >
      <text>政策</text>
    </view>
    <view
      class="tab-item {{currentTab === 'contract' ? 'active' : ''}}"
      bindtap="onSwitchTab"
      data-tab="contract"
    >
      <text>合同</text>
    </view>
  </view>

  <view class="agreement-content">
    <!-- 协议列表 -->
    <view class="doc-list" wx:if="{{currentTab === 'agreement'}}">
      <block wx:if="{{agreements.length > 0}}">
        <view
          class="doc-card"
          wx:for="{{agreements}}"
          wx:key="id"
          bindtap="onOpenDoc"
          data-doc="{{item}}"
        >
          <view class="doc-icon">📄</view>
          <view class="doc-info">
            <text class="doc-title">{{item.title}}</text>
            <text class="doc-meta">版本 v{{item.version}} · {{item.update_time}}</text>
          </view>
          <text class="doc-arrow">›</text>
        </view>
      </block>
      <view class="empty-state" wx:else>
        <text>暂无协议文档</text>
      </view>
    </view>

    <!-- 政策列表 -->
    <view class="doc-list" wx:if="{{currentTab === 'policy'}}">
      <block wx:if="{{policies.length > 0}}">
        <view
          class="doc-card"
          wx:for="{{policies}}"
          wx:key="id"
          bindtap="onOpenDoc"
          data-doc="{{item}}"
        >
          <view class="doc-icon">📋</view>
          <view class="doc-info">
            <text class="doc-title">{{item.title}}</text>
            <text class="doc-meta">版本 v{{item.version}} · {{item.update_time}}</text>
          </view>
          <text class="doc-arrow">›</text>
        </view>
      </block>
      <view class="empty-state" wx:else>
        <text>暂无政策文档</text>
      </view>
    </view>

    <!-- 合同列表 -->
    <view class="doc-list" wx:if="{{currentTab === 'contract'}}">
      <block wx:if="{{contracts.length > 0}}">
        <view
          class="doc-card"
          wx:for="{{contracts}}"
          wx:key="id"
          bindtap="onOpenDoc"
          data-doc="{{item}}"
        >
          <view class="doc-icon">📝</view>
          <view class="doc-info">
            <text class="doc-title">{{item.title}}</text>
            <text class="doc-meta">版本 v{{item.version}} · {{item.update_time}}</text>
          </view>
          <text class="doc-arrow">›</text>
        </view>
      </block>
      <view class="empty-state" wx:else>
        <text>暂无合同文档</text>
      </view>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>