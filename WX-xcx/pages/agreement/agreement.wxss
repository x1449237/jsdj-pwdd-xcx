.agreement-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

.agreement-tabs {
  display: flex;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.tab-item.active {
  color: #1a1a2e;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
  border-radius: 2rpx;
}

.agreement-content {
  flex: 1;
  overflow-y: auto;
}

.doc-list {
  padding: 16rpx 32rpx;
}

.doc-card {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.doc-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
}

.doc-info {
  flex: 1;
}

.doc-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 6rpx;
}

.doc-meta {
  font-size: 24rpx;
  color: #999999;
}

.doc-arrow {
  font-size: 36rpx;
  color: #cccccc;
}

.empty-state {
  text-align: center;
  padding: 100rpx 32rpx;
  font-size: 28rpx;
  color: #999999;
}

.loading-state {
  text-align: center;
  padding: 100rpx;
  font-size: 28rpx;
  color: #999999;
}