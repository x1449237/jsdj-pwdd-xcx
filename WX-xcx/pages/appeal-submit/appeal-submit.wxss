.appeal-submit-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 200rpx;
}

.appeal-header {
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
  padding: 40rpx 32rpx;
}

.appeal-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.appeal-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

.appeal-form {
  padding: 32rpx;
}

/* 申诉类型 */
.appeal-type-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.type-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  border: 2rpx solid #eeeeee;
  transition: all 0.3s;
}

.type-item.active {
  border-color: #e94560;
  background-color: rgba(233, 69, 96, 0.05);
}

.type-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.type-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 4rpx;
}

.type-desc {
  display: block;
  font-size: 22rpx;
  color: #999999;
}

/* 表单 */
.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.label-tip {
  font-size: 22rpx;
  color: #999999;
  font-weight: normal;
  margin-left: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 16rpx 24rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.form-count {
  text-align: right;
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}

.form-placeholder {
  color: #999999;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker-arrow {
  font-size: 32rpx;
  color: #cccccc;
}

/* 视频上传 */
.video-upload {
  margin-top: 8rpx;
}

.upload-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 240rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  border: 2rpx dashed #dddddd;
}

.upload-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.upload-text {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 6rpx;
}

.upload-tip {
  font-size: 22rpx;
  color: #cccccc;
}

.upload-text-sm {
  font-size: 22rpx;
  color: #999999;
}

.video-preview {
  background-color: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
}

.preview-video {
  width: 100%;
  height: 360rpx;
}

.video-actions {
  display: flex;
  justify-content: flex-end;
  padding: 16rpx 24rpx;
  gap: 24rpx;
}

.action-btn {
  font-size: 26rpx;
  color: #e94560;
}

.action-btn.delete {
  color: #999999;
}

/* 图片上传 */
.image-upload {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.image-preview {
  width: 100%;
  height: 100%;
}

.image-delete {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(0, 0, 0, 0.5);
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 0 12rpx 0 12rpx;
}

.image-upload-area {
  width: 200rpx;
  height: 200rpx;
}

/* 提交 */
.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}