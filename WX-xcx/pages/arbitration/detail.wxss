.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 36rpx;
  color: #333;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.placeholder {
  width: 60rpx;
}

.status-card {
  margin: 20rpx 30rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.status-left {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.case-id {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.status-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.dispute-type {
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #fff;
}

.section {
  background: #fff;
  margin: 20rpx 30rpx;
  padding: 30rpx;
  border-radius: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #e94560;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.info-label {
  font-size: 28rpx;
  color: #999;
}

.info-value {
  font-size: 28rpx;
  color: #333;
}

.description-box {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.evidence-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.evidence-item {
  display: flex;
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
}

.evidence-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.evidence-video,
.evidence-audio {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background: #333;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.video-icon,
.audio-icon {
  font-size: 40rpx;
  color: #fff;
}

.video-label,
.audio-label {
  font-size: 22rpx;
  color: #fff;
  margin-top: 8rpx;
}

.evidence-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.evidence-desc {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
}

.evidence-uploader {
  font-size: 24rpx;
  color: #999;
}

.result-box {
  background: #f0f9eb;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #67c23a;
  line-height: 1.6;
  border-left: 6rpx solid #67c23a;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}
