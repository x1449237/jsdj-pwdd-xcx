.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 36rpx;
  color: #333;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.placeholder {
  width: 60rpx;
}

.section {
  background: #fff;
  margin-top: 20rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.dispute-types {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.dispute-item {
  padding: 16rpx 32rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.dispute-item.active {
  background: rgba(233, 69, 96, 0.1);
  color: #e94560;
  border-color: #e94560;
}

.guide-box {
  background: #f0f9ff;
  border-radius: 16rpx;
  padding: 24rpx;
  border-left: 6rpx solid #409eff;
}

.guide-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #303133;
  margin-bottom: 12rpx;
}

.guide-desc {
  font-size: 26rpx;
  color: #606266;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.required-items {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.required-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
}

.required-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

.required-tag.required {
  background: #fef0f0;
  color: #f56c6c;
}

.required-tag.optional {
  background: #f0f9ff;
  color: #409eff;
}

.item-label {
  color: #606266;
}

.textarea-box {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 24rpx;
  position: relative;
}

.desc-textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  color: #333;
}

.word-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

.evidence-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.evidence-item {
  width: 200rpx;
  position: relative;
}

.evidence-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  display: block;
}

.evidence-video {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background: #333;
  display: flex;
  align-items: center;
  justify-content: center;
}

.video-icon {
  font-size: 48rpx;
  color: #fff;
}

.evidence-desc-input {
  margin-top: 8rpx;
}

.desc-input {
  width: 100%;
  height: 48rpx;
  font-size: 22rpx;
  color: #333;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 12rpx;
  box-sizing: border-box;
}

.delete-btn {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  line-height: 1;
}

.add-evidence {
  width: 200rpx;
  height: 200rpx;
  background: #f5f5f5;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.add-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(90deg, #e94560, #ff6b6b);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
}

.submit-btn.disabled {
  opacity: 0.6;
}
