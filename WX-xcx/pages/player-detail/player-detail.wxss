.player-detail-page {
  padding-bottom: 140rpx;
  background-color: #f5f5f5;
}

/* 头部 */
.player-header {
  position: relative;
  padding-bottom: 40rpx;
}

.player-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 320rpx;
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
}

.player-header-content {
  position: relative;
  display: flex;
  padding: 40rpx 32rpx 0;
}

.player-avatar-lg {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 24rpx;
  background-color: #f0f0f0;
}

.player-basic-info {
  flex: 1;
  padding-top: 12rpx;
}

.player-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.player-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  margin-right: 8rpx;
}

.player-gender {
  font-size: 28rpx;
  color: #e94560;
  margin-right: 12rpx;
}

.online-badge {
  padding: 4rpx 12rpx;
  background-color: #07c160;
  border-radius: 4rpx;
  font-size: 20rpx;
  color: #ffffff;
}

.player-tags {
  margin-bottom: 12rpx;
}

.player-rank-info {
  margin-bottom: 8rpx;
}

/* 数据统计 */
.stats-section {
  display: flex;
  align-items: center;
  margin: 16rpx 32rpx;
  padding: 24rpx 0;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999999;
}

.stat-divider {
  width: 1rpx;
  height: 40rpx;
  background-color: #eeeeee;
}

/* 简介 */
.intro-section {
  margin: 16rpx 32rpx;
  padding: 24rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.intro-content {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
}

/* 服务 */
.service-section {
  margin: 16rpx 32rpx;
  padding: 24rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.title-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.title-more {
  font-size: 24rpx;
  color: #999999;
}

.service-list {
  display: flex;
  flex-direction: column;
}

.service-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.service-item:last-child {
  border-bottom: none;
}

.service-info {
  flex: 1;
}

.service-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 4rpx;
}

.service-desc {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 4rpx;
}

.service-duration {
  font-size: 22rpx;
  color: #cccccc;
}

.service-price {
  text-align: right;
  margin-left: 20rpx;
}

.service-price .price-symbol {
  font-size: 24rpx;
  color: #e94560;
  font-weight: bold;
}

.service-price .price-value {
  font-size: 36rpx;
  color: #e94560;
  font-weight: bold;
}

.service-price .price-unit {
  font-size: 22rpx;
  color: #999999;
}

/* 评价 */
.review-section {
  margin: 16rpx 32rpx;
  padding: 24rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.review-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.review-item:last-child {
  border-bottom: none;
}

.review-user {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.review-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  background-color: #f0f0f0;
}

.review-user-info {
  flex: 1;
}

.review-user-name {
  font-size: 26rpx;
  color: #333333;
  display: block;
  margin-bottom: 4rpx;
}

.review-stars {
  display: flex;
}

.star {
  font-size: 24rpx;
  color: #eeeeee;
  margin-right: 4rpx;
}

.star.active {
  color: #ffd700;
}

.review-time {
  font-size: 22rpx;
  color: #cccccc;
}

.review-content {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.review-tags {
  display: flex;
  flex-wrap: wrap;
}

.review-tag {
  padding: 4rpx 12rpx;
  background-color: #f5f5f5;
  border-radius: 4rpx;
  font-size: 20rpx;
  color: #999999;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

/* 底部栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.bottom-price {
  display: flex;
  align-items: baseline;
  margin-right: 24rpx;
}

.price-label {
  font-size: 24rpx;
  color: #999999;
  margin-right: 4rpx;
}

.bottom-price .price-symbol {
  font-size: 24rpx;
  color: #e94560;
  font-weight: bold;
}

.bottom-price .price-value {
  font-size: 40rpx;
  color: #e94560;
  font-weight: bold;
}

.bottom-price .price-unit {
  font-size: 22rpx;
  color: #999999;
}

.order-btn {
  flex: 1;
  height: 80rpx;
  font-size: 30rpx;
  border-radius: 40rpx;
}

.favorite-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 12rpx;
  margin-left: 16rpx;
}

.favorite-btn.favorited {
  background: rgba(255, 107, 53, 0.2);
}

.favorite-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.favorite-text {
  font-size: 20rpx;
  color: #fff;
}

.tags-section {
  margin: 16rpx 32rpx;
  padding: 24rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.tags-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.tag-group {
  display: flex;
  flex-direction: column;
}

.group-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.detail-tag {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  line-height: 1.4;
}

.tag-game {
  background: #ecf5ff;
  color: #409eff;
}

.tag-rank {
  background: #fdf6ec;
  color: #e6a23c;
}

.tag-position {
  background: #f0f9eb;
  color: #67c23a;
}

.tag-voice {
  background: #fef0f0;
  color: #f56c6c;
}

.tag-skill {
  background: #f4f4f5;
  color: #909399;
}