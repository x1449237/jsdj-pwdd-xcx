.my-orders-page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* Tab */
.tabs {
  display: flex;
  background-color: #ffffff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.tab-item.active {
  color: #e94560;
  font-weight: 500;
}

.tab-line {
  position: absolute;
  bottom: 0;
  width: 40rpx;
  height: 4rpx;
  background-color: #e94560;
  border-radius: 2rpx;
}

/* 订单卡片 */
.order-list {
  padding: 16rpx 32rpx;
}

.order-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.order-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.order-no {
  font-size: 24rpx;
  color: #999999;
}

.order-status {
  font-size: 26rpx;
  font-weight: 500;
}

.order-body {
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
  margin-bottom: 20rpx;
}

.order-game-info {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.game-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
  margin-right: 16rpx;
}

.game-detail {
  flex: 1;
}

.game-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 4rpx;
}

.service-name {
  font-size: 24rpx;
  color: #999999;
}

.order-player-info {
  display: flex;
  align-items: center;
}

.player-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  margin-right: 12rpx;
}

.player-detail {
  flex: 1;
}

.player-name {
  display: block;
  font-size: 26rpx;
  color: #333333;
}

.player-rank {
  font-size: 22rpx;
  color: #999999;
}

.order-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.order-amount {
  display: flex;
  align-items: baseline;
}

.amount-symbol {
  font-size: 24rpx;
  color: #e94560;
  font-weight: bold;
}

.amount-value {
  font-size: 36rpx;
  color: #e94560;
  font-weight: bold;
}

.order-actions {
  display: flex;
  gap: 12rpx;
}

.order-actions .btn-sm {
  padding: 0 20rpx;
  height: 56rpx;
  font-size: 24rpx;
}