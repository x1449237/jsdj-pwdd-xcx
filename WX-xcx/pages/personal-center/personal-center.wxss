.personal-center-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 用户卡片 */
.user-card {
  position: relative;
  margin-bottom: 16rpx;
}

.user-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 360rpx;
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
}

.user-info {
  position: relative;
  display: flex;
  align-items: center;
  padding: 60rpx 32rpx 30rpx;
}

.avatar-btn {
  background: none;
  padding: 0;
  border: none;
  line-height: 1;
  margin-right: 24rpx;
}

.avatar-btn::after {
  border: none;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  overflow: hidden;
  margin-right: 24rpx;
}

.avatar-img {
  width: 100%;
  height: 100%;
  background-color: #f0f0f0;
}

.user-detail {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.user-phone {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 实名认证提示 */
.real-name-tip {
  position: relative;
  display: flex;
  align-items: center;
  margin: 0 32rpx;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #fff3e0, #ffe0b2);
  border-radius: 8rpx;
  border-left: 4rpx solid #ff6d00;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.tip-text {
  flex: 1;
  font-size: 24rpx;
  color: #e65100;
}

.tip-arrow {
  font-size: 32rpx;
  color: #e65100;
}

/* 余额 */
.balance-section {
  position: relative;
  display: flex;
  margin: 20rpx 32rpx 0;
  padding: 24rpx 0;
  background-color: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
}

.balance-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.balance-item:first-child {
  border-right: 1rpx solid rgba(255, 255, 255, 0.2);
}

.balance-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 8rpx;
}

.balance-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffd700;
}

.balance-arrow {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 菜单 */
.menu-section {
  padding: 0 32rpx;
}

.menu-group {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}

.menu-name {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.menu-arrow {
  font-size: 32rpx;
  color: #cccccc;
}

/* 加入我们 */
.join-us-section {
  padding: 40rpx 32rpx;
}

.join-us-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border: 1px dashed #cccccc;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #999999;
}

/* 退出登录 */
.logout-section {
  padding: 20rpx 32rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #e94560;
  border: none;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.logout-btn::after {
  border: none;
}