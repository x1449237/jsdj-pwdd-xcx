<view class="personal-center-page">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-bg"></view>
    <view class="user-info">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar" wx:if="{{isLogin}}">
        <image class="user-avatar" src="{{userInfo.avatar || '/assets/images/default-avatar.png'}}" mode="aspectFill"></image>
      </button>
      <view class="user-avatar" wx:else bindtap="onLogin">
        <image class="avatar-img" src="/assets/images/default-avatar.png" mode="aspectFill"></image>
      </view>
      <view class="user-detail" wx:if="{{isLogin}}">
        <text class="user-name">{{userInfo.nickname || '未设置昵称'}}</text>
        <text class="user-phone">{{userInfo.phone || ''}}</text>
      </view>
      <view class="user-detail" wx:else bindtap="onLogin">
        <text class="user-name">点击登录</text>
        <text class="user-phone">登录后可体验更多功能</text>
      </view>
    </view>

    <!-- 实名认证提示 -->
    <view class="real-name-tip" wx:if="{{isLogin && !userInfo.is_real_name}}" bindtap="onRealNameAuth">
      <text class="tip-icon">⚠️</text>
      <text class="tip-text">请完成实名认证，否则无法正常使用</text>
      <text class="tip-arrow">›</text>
    </view>

    <!-- 余额 -->
    <view class="balance-section" wx:if="{{isLogin}}">
      <view class="balance-item" bindtap="onBalance">
        <text class="balance-label">余额</text>
        <text class="balance-value">¥{{balance}}</text>
      </view>
      <view class="balance-item" bindtap="onWithdraw">
        <text class="balance-label">提现</text>
        <text class="balance-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-section">
    <view class="menu-group">
      <view class="menu-item" bindtap="onMyOrders">
        <image class="menu-icon" src="/assets/icons/menu-order.png" mode="aspectFit"></image>
        <text class="menu-name">我的订单</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onMyReviews">
        <image class="menu-icon" src="/assets/icons/menu-review.png" mode="aspectFit"></image>
        <text class="menu-name">评价管理</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onAppealCenter">
        <image class="menu-icon" src="/assets/icons/menu-appeal.png" mode="aspectFit"></image>
        <text class="menu-name">申诉中心</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-item" bindtap="onSettings">
        <image class="menu-icon" src="/assets/icons/menu-settings.png" mode="aspectFit"></image>
        <text class="menu-name">设置</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onAbout">
        <image class="menu-icon" src="/assets/icons/menu-about.png" mode="aspectFit"></image>
        <text class="menu-name">关于我们</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 加入我们 -->
  <view class="join-us-section">
    <view class="join-us-btn" bindtap="onJoinUs">
      <text>加入我们</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section" wx:if="{{isLogin}}">
    <button class="logout-btn" bindtap="onLogout">退出登录</button>
  </view>
</view>