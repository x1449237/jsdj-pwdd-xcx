.club-detail-page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.club-header {
  padding: 48rpx 32rpx 32rpx;
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
}

.club-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.club-name {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  margin-right: 16rpx;
}

.club-type-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

.stats-section {
  display: flex;
  margin: 16rpx 32rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-item:first-child {
  border-right: 1rpx solid #f0f0f0;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #0f3460;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
}

.founder-section {
  margin: 16rpx 32rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

.founder-card {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.founder-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background-color: #f0f0f0;
}

.founder-info {
  flex: 1;
}

.founder-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 4rpx;
}

.founder-id {
  font-size: 24rpx;
  color: #999999;
}

.loading-state {
  text-align: center;
  padding: 100rpx;
  font-size: 28rpx;
  color: #999999;
}