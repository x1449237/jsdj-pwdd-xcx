.club-detail-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

.club-header {
  padding: 48rpx 32rpx 32rpx;
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
}

.club-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.club-name {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  margin-right: 16rpx;
}

.club-type-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  display: block;
}

.club-abbr {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 8rpx;
  display: block;
}

.stats-section {
  display: flex;
  margin: 16rpx 32rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-right: 1rpx solid #f0f0f0;
}
.stat-item:last-child { border-right: none; }

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #0f3460;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
}

.founder-section {
  margin: 16rpx 32rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

.founder-card {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.founder-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background-color: #f0f0f0;
}

.founder-info {
  flex: 1;
}

.founder-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 4rpx;
}

.founder-id {
  font-size: 24rpx;
  color: #999999;
}

.action-bar {
  padding: 20rpx 32rpx;
}

.btn-manage, .btn-join {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  color: #fff;
}

.btn-manage {
  background: linear-gradient(135deg, #409EFF, #66b1ff);
}

.btn-join {
  background: linear-gradient(135deg, #67C23A, #85ce61);
}

.tab-section {
  margin: 16rpx 32rpx 0;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.tab-bar {
  display: flex;
  white-space: nowrap;
  border-bottom: 1rpx solid #eee;
  padding: 0 20rpx;
}

.tab-item {
  display: inline-block;
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  color: #606266;
  position: relative;
}

.tab-item.active {
  color: #409EFF;
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: #409EFF;
  border-radius: 3rpx;
}

.tab-content {
  padding: 24rpx;
  min-height: 300rpx;
}

.tab-pane {
  animation: fadeIn 0.3s;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.empty-tab {
  text-align: center;
  padding: 80rpx 0;
  color: #c0c4cc;
  font-size: 28rpx;
}

.announcement-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f2f5;
  position: relative;
}
.announcement-item:last-child { border-bottom: none; }

.announcement-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  background: #fef0f0;
  color: #f56c6c;
  font-size: 20rpx;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.announcement-title {
  font-size: 28rpx;
  color: #303133;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.announcement-content {
  font-size: 26rpx;
  color: #606266;
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.announcement-time {
  font-size: 22rpx;
  color: #c0c4cc;
}

.coupon-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.coupon-mini {
  display: flex;
  background: #fff;
  border: 1rpx solid #ebeef5;
  border-radius: 12rpx;
  overflow: hidden;
}

.coupon-mini-left {
  width: 180rpx;
  background: linear-gradient(135deg, #ff6b6b, #feca57);
  color: #fff;
  padding: 20rpx;
  text-align: center;
}

.coupon-mini-value {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
}

.coupon-mini-condition {
  font-size: 20rpx;
  opacity: 0.9;
  margin-top: 4rpx;
  display: block;
}

.coupon-mini-right {
  flex: 1;
  padding: 16rpx 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.coupon-mini-name {
  font-size: 26rpx;
  color: #303133;
  font-weight: 500;
}

.coupon-mini-time {
  font-size: 20rpx;
  color: #909399;
}

.btn-receive-mini {
  align-self: flex-end;
  background: #f56c6c !important;
  color: #fff !important;
  border-radius: 30rpx !important;
  font-size: 22rpx !important;
  padding: 0 20rpx !important;
  line-height: 48rpx !important;
}

.dynamic-mini-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.dynamic-mini-item {
  padding: 16rpx;
  background: #fafafa;
  border-radius: 12rpx;
}

.dynamic-mini-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.dynamic-mini-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.dynamic-mini-info {
  flex: 1;
}

.dynamic-mini-nick {
  font-size: 26rpx;
  color: #303133;
  display: block;
}

.dynamic-mini-time {
  font-size: 20rpx;
  color: #c0c4cc;
}

.dynamic-mini-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #303133;
  margin-bottom: 6rpx;
}

.dynamic-mini-content {
  font-size: 24rpx;
  color: #606266;
  line-height: 1.5;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.dynamic-mini-footer {
  display: flex;
  gap: 24rpx;
  font-size: 22rpx;
  color: #909399;
}

.more-btn {
  text-align: center;
  padding: 24rpx 0 8rpx;
  font-size: 26rpx;
  color: #409EFF;
}

.branch-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.branch-item {
  padding: 20rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
}

.branch-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #303133;
  margin-bottom: 8rpx;
}

.branch-game, .branch-manager {
  font-size: 24rpx;
  color: #606266;
  margin-top: 4rpx;
}

.loading-state {
  text-align: center;
  padding: 100rpx;
  font-size: 28rpx;
  color: #999999;
}
