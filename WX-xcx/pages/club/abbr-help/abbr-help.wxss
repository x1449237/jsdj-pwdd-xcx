.help-page {
  padding: 32rpx;
  background-color: #ffffff;
  min-height: 100vh;
}
.section {
  margin-bottom: 40rpx;
}
.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 16rpx;
  line-height: 1.4;
}
.text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.8;
  margin-bottom: 8rpx;
}
.text.rule {
  color: #e74c3c;
  font-weight: 600;
}
.example {
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  margin: 12rpx 0;
}
.example text {
  display: block;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.8;
}
.bad {
  color: #e74c3c !important;
}
.good {
  color: #52c41a !important;
}