.club-join-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

.page-header {
  padding: 40rpx 32rpx 20rpx;
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.page-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

.form-section {
  margin: 16rpx 32rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.form-group {
  margin-bottom: 32rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333333;
}

.picker-arrow {
  font-size: 36rpx;
  color: #cccccc;
}

.form-hint {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

/* 预览 */
.preview-section {
  margin: 16rpx 32rpx;
}

.preview-title {
  display: block;
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

.preview-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.preview-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.preview-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-right: 12rpx;
}

.preview-type {
  font-size: 24rpx;
  color: #999999;
}

/* 提交 */
.submit-section {
  padding: 40rpx 32rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn[disabled] {
  background: #cccccc;
  color: #999999;
}

.submit-btn::after {
  border: none;
}