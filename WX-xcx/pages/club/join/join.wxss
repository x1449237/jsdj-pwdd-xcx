.join-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 步骤指示器 */
.step-indicator {
  padding: 24rpx 32rpx 8rpx;
  background-color: #ffffff;
}
.step-bar {
  height: 6rpx;
  background-color: #e8e8e8;
  border-radius: 3rpx;
  margin-bottom: 8rpx;
}
.step-fill {
  height: 100%;
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
  border-radius: 3rpx;
  transition: width 0.3s;
}
.step-text {
  font-size: 24rpx;
  color: #999999;
}

/* 步骤主体 */
.step-body {
  padding: 32rpx 32rpx;
}
.step-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 24rpx;
}

/* 步骤1：须知 */
.notice-content {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.notice-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}
.notice-text {
  display: block;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.7;
  margin-bottom: 4rpx;
}
.agreement-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
}
.agreement-item {
  display: flex;
  align-items: center;
}
.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #cccccc;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.checkbox.checked {
  background-color: #0f3460;
  border-color: #0f3460;
}
.checkbox.checked text {
  color: #ffffff;
  font-size: 24rpx;
}
.agreement-text {
  font-size: 26rpx;
  color: #333333;
}

/* 步骤2：基础资料 */
.form-group {
  margin-bottom: 24rpx;
}
.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}
.form-input {
  width: 100%;
  height: 80rpx;
  background-color: #ffffff;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 12rpx;
  box-sizing: border-box;
}

/* 缩写 */
.abbr-section {
  background-color: #f0f4ff;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
}
.abbr-row {
  display: flex;
  align-items: center;
  margin-bottom: 4rpx;
}
.abbr-label { font-size: 26rpx; color: #666666; }
.abbr-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #0f3460;
  letter-spacing: 4rpx;
}
.abbr-value.occupied { color: #e74c3c; }
.abbr-status { font-size: 24rpx; color: #e74c3c; margin-left: 12rpx; }
.abbr-status.ok { color: #52c41a; }
.abbr-desc { font-size: 22rpx; color: #999999; }

.abbr-alert {
  background-color: #fff2f0;
  border: 1rpx solid #ffccc7;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
}
.abbr-alert-title {
  display: block;
  font-size: 26rpx;
  color: #e74c3c;
  margin-bottom: 8rpx;
}
.abbr-alert-link {
  font-size: 26rpx;
  color: #1890ff;
  text-decoration: underline;
}

/* 步骤3：活体 */
.upload-group {
  margin-bottom: 24rpx;
}
.upload-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}
.upload-box {
  width: 100%;
  height: 300rpx;
  background-color: #ffffff;
  border: 2rpx dashed #cccccc;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.upload-box.file {
  height: 120rpx;
}
.upload-preview {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}
.upload-placeholder {
  font-size: 28rpx;
  color: #cccccc;
}
.upload-file-name {
  font-size: 26rpx;
  color: #333333;
  padding: 0 20rpx;
  word-break: break-all;
}
.upload-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 8rpx;
}
.action-link {
  font-size: 26rpx;
  color: #1890ff;
  margin-left: 24rpx;
}

.liveness-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
}
.liveness-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}
.liveness-btn {
  width: 300rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #ffffff;
  border: none;
  margin: 0 auto;
}
.liveness-btn::after { border: none; }
.liveness-passed {
  font-size: 28rpx;
  color: #52c41a;
  padding: 20rpx 0;
}

/* 步骤4：合同 */
.contract-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  text-align: center;
}
.contract-btn {
  width: 100%;
  height: 80rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  border: none;
  margin-bottom: 12rpx;
}
.contract-btn.download {
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
  color: #ffffff;
}
.contract-btn::after { border: none; }
.contract-hint {
  font-size: 24rpx;
  color: #999999;
}

/* 步骤5：预览 */
.preview-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}
.preview-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.preview-item:last-child { border-bottom: none; }
.preview-label {
  font-size: 26rpx;
  color: #999999;
  width: 160rpx;
  flex-shrink: 0;
}
.preview-value {
  font-size: 28rpx;
  color: #333333;
  flex: 1;
  word-break: break-all;
}
.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  border: none;
}
.submit-btn[disabled] { background: #cccccc; color: #999999; }
.submit-btn::after { border: none; }

/* 底部导航 */
.step-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 16rpx 32rpx;
  background-color: #ffffff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}
.footer-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  border: none;
}
.footer-btn::after { border: none; }
.footer-btn.prev {
  background-color: #f5f5f5;
  color: #666666;
  margin-right: 16rpx;
}
.footer-btn.next {
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
  color: #ffffff;
}