<view class="join-page">
  <!-- 步骤指示器 -->
  <view class="step-indicator">
    <view class="step-bar">
      <view class="step-fill" style="width: {{step / totalSteps * 100}}%"></view>
    </view>
    <text class="step-text">步骤 {{step}} / {{totalSteps}}</text>
  </view>

  <!-- ====== 步骤1：入驻须知 ====== -->
  <view class="step-body" wx:if="{{step === 1}}">
    <view class="step-title">入驻须知</view>
    <view class="notice-content">
      <text class="notice-title">平台入驻规则</text>
      <text class="notice-text">1. 俱乐部入驻需通过平台人工审核，预计3个工作日内完成。</text>
      <text class="notice-text">2. 申请人须年满16周岁，需完成实名活体认证。</text>
      <text class="notice-text">3. 俱乐部名称一经审核通过不可修改，请慎重命名。</text>
      <text class="notice-text">4. 俱乐部将由系统自动生成唯一缩写，作为订单号前缀。</text>

      <text class="notice-title" style="margin-top: 20rpx;">保证金说明</text>
      <text class="notice-text" wx:if="{{isEnterprise}}">企业俱乐部保证金：{{enterpriseDeposit}} 元</text>
      <text class="notice-text" wx:else>个人俱乐部保证金：{{personalDeposit}} 元</text>
      <text class="notice-text">审核通过后缴纳保证金，俱乐部正式生效。</text>
    </view>

    <view class="agreement-section">
      <view class="agreement-item" bindtap="toggleAgree">
        <view class="checkbox {{agreed ? 'checked' : ''}}">
          <text wx:if="{{agreed}}">✓</text>
        </view>
        <text class="agreement-text">我已阅读并同意全部协议（入驻规则、合同、隐私政策）</text>
      </view>
    </view>
  </view>

  <!-- ====== 步骤2：基础资料 ====== -->
  <view class="step-body" wx:if="{{step === 2}}">
    <view class="step-title">基础资料</view>

    <view class="form-group">
      <view class="form-label">俱乐部名称</view>
      <input class="form-input" placeholder="请输入俱乐部中文名称（2-50字）" maxlength="50" value="{{clubName}}" bindinput="onClubNameInput" />
    </view>

    <!-- 缩写展示 -->
    <view class="abbr-section" wx:if="{{abbreviation}}">
      <view class="abbr-row">
        <text class="abbr-label">系统缩写：</text>
        <text class="abbr-value {{abbrOccupied ? 'occupied' : ''}}">{{abbreviation}}</text>
        <text class="abbr-status" wx:if="{{abbrOccupied}}">已被占用</text>
        <text class="abbr-status ok" wx:else>可用</text>
      </view>
      <view class="abbr-desc">订单号格式：{{abbreviation}}-年月日时分</view>
    </view>

    <!-- 缩写占用弹窗 -->
    <view class="abbr-alert" wx:if="{{abbrOccupied}}">
      <text class="abbr-alert-title">检测到俱乐部缩写被占用，请更换俱乐部名称</text>
      <text class="abbr-alert-link" bindtap="onAbbrHelp">对缩写占用有疑惑？</text>
    </view>

    <view class="form-group">
      <view class="form-label">真实姓名</view>
      <input class="form-input" placeholder="请输入真实姓名" value="{{realName}}" bindinput="onInput" data-field="realName" />
    </view>
    <view class="form-group">
      <view class="form-label">身份证号码</view>
      <input class="form-input" type="idcard" placeholder="请输入18位身份证号码" maxlength="18" value="{{idCard}}" bindinput="onInput" data-field="idCard" />
    </view>
    <view class="form-group">
      <view class="form-label">手机号</view>
      <input class="form-input" type="number" placeholder="请输入本人实名手机号" maxlength="11" value="{{phone}}" bindinput="onInput" data-field="phone" />
    </view>
    <view class="form-group">
      <view class="form-label">详细地址</view>
      <input class="form-input" placeholder="省" value="{{addressProvince}}" bindinput="onInput" data-field="addressProvince" />
      <input class="form-input" placeholder="市" value="{{addressCity}}" bindinput="onInput" data-field="addressCity" />
      <input class="form-input" placeholder="区/县" value="{{addressDistrict}}" bindinput="onInput" data-field="addressDistrict" />
      <input class="form-input" placeholder="乡镇街道/小区/楼栋/单元/楼层/户号" value="{{addressDetail}}" bindinput="onInput" data-field="addressDetail" />
    </view>
  </view>

  <!-- ====== 步骤3：活体认证 ====== -->
  <view class="step-body" wx:if="{{step === 3}}">
    <view class="step-title">实名活体认证</view>

    <view class="upload-group">
      <view class="upload-label">身份证正面</view>
      <view class="upload-box" bindtap="onUploadImage" data-field="idCardFront">
        <image wx:if="{{idCardFront}}" class="upload-preview" src="{{idCardFront}}" mode="aspectFit" />
        <text wx:else class="upload-placeholder">+ 点击上传</text>
      </view>
    </view>
    <view class="upload-group">
      <view class="upload-label">身份证反面</view>
      <view class="upload-box" bindtap="onUploadImage" data-field="idCardBack">
        <image wx:if="{{idCardBack}}" class="upload-preview" src="{{idCardBack}}" mode="aspectFit" />
        <text wx:else class="upload-placeholder">+ 点击上传</text>
      </view>
    </view>

    <view class="liveness-section">
      <view class="liveness-label">活体人脸识别</view>
      <button class="liveness-btn" bindtap="onLivenessCheck" wx:if="{{livenessStatus === 0}}">开始人脸识别</button>
      <view class="liveness-passed" wx:if="{{livenessStatus === 1}}">已通过人脸识别</view>
    </view>
  </view>

  <!-- ====== 步骤4：合同上传 ====== -->
  <view class="step-body" wx:if="{{step === 4}}">
    <view class="step-title">入驻合同</view>

    <view class="contract-section">
      <button class="contract-btn download" bindtap="onDownloadTemplate">下载{{isEnterprise ? '企业版' : '个人版'}}入驻PDF合同</button>
      <text class="contract-hint">请下载打印、手写签名、按手印{{isEnterprise ? '、加盖企业公章' : ''}}，扫描为PDF文件上传</text>
    </view>

    <view class="upload-group">
      <view class="upload-label">上传已签署合同</view>
      <view class="upload-box file" bindtap="onUploadContract">
        <text wx:if="{{contractFile}}" class="upload-file-name">{{contractFile}}</text>
        <text wx:else class="upload-placeholder">+ 点击上传PDF文件</text>
      </view>
      <view class="upload-actions" wx:if="{{contractFile}}">
        <text class="action-link" bindtap="onPreviewContract">预览合同</text>
        <text class="action-link" bindtap="onUploadContract">重新上传</text>
      </view>
    </view>
  </view>

  <!-- ====== 步骤5：预览 ====== -->
  <view class="step-body" wx:if="{{step === 5}}">
    <view class="step-title">资料预览确认</view>

    <view class="preview-section">
      <view class="preview-item">
        <text class="preview-label">俱乐部名称</text>
        <text class="preview-value">{{clubName}}</text>
      </view>
      <view class="preview-item">
        <text class="preview-label">系统缩写</text>
        <text class="preview-value">{{abbreviation}}</text>
      </view>
      <view class="preview-item">
        <text class="preview-label">姓名</text>
        <text class="preview-value">{{realName}}</text>
      </view>
      <view class="preview-item">
        <text class="preview-label">身份证</text>
        <text class="preview-value">{{idCard}}</text>
      </view>
      <view class="preview-item">
        <text class="preview-label">手机号</text>
        <text class="preview-value">{{phone}}</text>
      </view>
      <view class="preview-item">
        <text class="preview-label">地址</text>
        <text class="preview-value">{{addressProvince}}{{addressCity}}{{addressDistrict}}{{addressDetail}}</text>
      </view>
      <view class="preview-item">
        <text class="preview-label">保证金</text>
        <text class="preview-value">{{isEnterprise ? enterpriseDeposit : personalDeposit}} 元</text>
      </view>
    </view>

    <view class="preview-submit">
      <button class="submit-btn" loading="{{submitting}}" disabled="{{submitting}}" bindtap="onSubmit">
        确认提交入驻申请
      </button>
    </view>
  </view>

  <!-- 底部导航按钮 -->
  <view class="step-footer">
    <button class="footer-btn prev" wx:if="{{step > 1}}" bindtap="prevStep">上一步</button>
    <button class="footer-btn next" wx:if="{{step < 5}}" bindtap="nextStep">下一步</button>
  </view>
</view>