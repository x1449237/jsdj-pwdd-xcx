.page {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 40rpx;
}

.stat-cards {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 20rpx;
}

.stat-card {
  padding: 30rpx;
  border-radius: 16rpx;
  color: #fff;
}
.stat-card.primary { background: linear-gradient(135deg, #409EFF, #66b1ff); }
.stat-card.success { background: linear-gradient(135deg, #67C23A, #85ce61); }
.stat-card.warning { background: linear-gradient(135deg, #E6A23C, #ebb563); }
.stat-card.info    { background: linear-gradient(135deg, #909399, #a6a9ad); }

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}

.section {
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #303133;
}

.days-tabs {
  display: flex;
  background: #f0f2f5;
  border-radius: 30rpx;
  padding: 4rpx;
}

.day-item {
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  color: #606266;
  border-radius: 30rpx;
}

.day-item.active {
  background: #409EFF;
  color: #fff;
}

.chart-wrap {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  padding: 20rpx 0;
  min-height: 300rpx;
}

.chart-bar {
  flex: 0 0 auto;
  width: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bar-value {
  font-size: 20rpx;
  color: #606266;
  margin-bottom: 8rpx;
}

.bar-bg {
  width: 24rpx;
  height: 200rpx;
  background: #f0f2f5;
  border-radius: 12rpx 12rpx 0 0;
  display: flex;
  align-items: flex-end;
}

.bar-fill {
  width: 100%;
  background: linear-gradient(to top, #409EFF, #66b1ff);
  border-radius: 12rpx 12rpx 0 0;
  transition: height 0.3s;
}

.bar-date {
  font-size: 20rpx;
  color: #909399;
  margin-top: 8rpx;
}

.empty-chart {
  text-align: center;
  padding: 60rpx 0;
  color: #c0c4cc;
  font-size: 26rpx;
}

.member-stats {
  display: flex;
  justify-content: space-around;
}

.member-stat-item {
  text-align: center;
}

.member-num {
  font-size: 32rpx;
  font-weight: bold;
  color: #303133;
}

.member-label {
  font-size: 24rpx;
  color: #909399;
  margin-top: 8rpx;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
  color: #909399;
}
