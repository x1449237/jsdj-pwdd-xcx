.appeal-list-page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.appeal-header {
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
  padding: 40rpx 32rpx;
}

.appeal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

.appeal-list {
  padding: 16rpx 32rpx;
}

.appeal-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.appeal-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.appeal-type {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.appeal-status {
  font-size: 26rpx;
  font-weight: 500;
}

.appeal-card-body {
  margin-bottom: 12rpx;
}

.appeal-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.appeal-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.appeal-time {
  font-size: 22rpx;
  color: #cccccc;
}

.appeal-card-arrow {
  font-size: 32rpx;
  color: #cccccc;
}