.detail-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 60rpx;
}

/* 状态时间线 */
.timeline-section {
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
  padding: 32rpx;
}

.status-header {
  margin-bottom: 32rpx;
}

.status-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.status-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

.timeline {
  padding-left: 8rpx;
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  position: relative;
  padding-bottom: 32rpx;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
  position: relative;
  z-index: 1;
}

.timeline-active .timeline-dot {
  background-color: #e94560;
}

.timeline-done .timeline-dot {
  background-color: #07c160;
}

.dot-icon {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: bold;
}

.dot-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.timeline-active .dot-text {
  color: #ffffff;
}

.timeline-content {
  flex: 1;
}

.timeline-title {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 4rpx;
}

.timeline-active .timeline-title,
.timeline-done .timeline-title {
  color: #ffffff;
}

.timeline-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.35);
}

.timeline-line {
  position: absolute;
  left: 29rpx;
  top: 44rpx;
  bottom: 0;
  width: 2rpx;
  background-color: rgba(255, 255, 255, 0.15);
}

.timeline-done .timeline-line {
  background-color: rgba(7, 193, 96, 0.5);
}

/* 信息卡片 */
.section {
  margin: 20rpx 0;
}

.section-title {
  padding: 0 32rpx 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #666666;
}

.info-card {
  background-color: #ffffff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.row-label {
  font-size: 26rpx;
  color: #999999;
}

.row-value {
  font-size: 26rpx;
  color: #333333;
  text-align: right;
  max-width: 60%;
}

/* 参与方 */
.participant-card {
  background-color: #ffffff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.participant {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.p-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
  margin-right: 20rpx;
}

.p-info {
  flex: 1;
}

.p-role {
  display: block;
  font-size: 22rpx;
  color: #e94560;
  margin-bottom: 4rpx;
}

.p-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 4rpx;
}

.p-rating {
  font-size: 24rpx;
  color: #999999;
}

.p-contact {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 20rpx;
  background-color: rgba(233, 69, 96, 0.06);
  border-radius: 12rpx;
}

.contact-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.contact-text {
  font-size: 22rpx;
  color: #e94560;
}

.divider {
  width: 100%;
  height: 1rpx;
  background-color: #f5f5f5;
  margin: 8rpx 0;
}

/* 聊天入口 */
.chat-entry {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
}

.chat-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.chat-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.chat-arrow {
  font-size: 28rpx;
  color: #cccccc;
}

/* 操作按钮 */
.action-section {
  padding: 16rpx 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  min-width: 200rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 40rpx;
  border: none;
  font-size: 28rpx;
}

.action-btn::after {
  border: none;
}

.btn-confirm {
  background: linear-gradient(135deg, #07c160, #06ad56);
  color: #ffffff;
}

.btn-evaluate {
  background: linear-gradient(135deg, #ff976a, #ff6b3d);
  color: #ffffff;
}

.btn-reward {
  background: linear-gradient(135deg, #ffd700, #ffb800);
  color: #333333;
}

.btn-outline {
  background-color: transparent;
  border: 2rpx solid #e94560;
  color: #e94560;
}

.service-timer {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.timer-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.timer-info {
  flex: 1;
}

.timer-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 8rpx;
}

.timer-duration {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  font-family: monospace;
}

.timer-status {
  display: flex;
  align-items: center;
  background: rgba(7, 193, 96, 0.2);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #07c160;
  margin-right: 8rpx;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.timer-status .status-text {
  font-size: 22rpx;
  color: #07c160;
}

.evidence-card {
  background-color: #ffffff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.upload-btn {
  font-size: 24rpx;
  color: #e94560;
}

.empty-evidence {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}

.empty-text {
  font-size: 24rpx;
  color: #999999;
}

.evidence-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.evidence-item {
  width: calc((100% - 32rpx) / 3);
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
}

.evidence-image {
  width: 100%;
  height: 180rpx;
  display: block;
}

.evidence-video {
  width: 100%;
  height: 180rpx;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.video-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.video-name {
  font-size: 20rpx;
  color: #999999;
}

.evidence-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
  padding: 12rpx 8rpx 8rpx;
}

.evidence-type {
  display: block;
  font-size: 20rpx;
  color: #ffffff;
  margin-bottom: 2rpx;
}

.evidence-time {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.7);
}