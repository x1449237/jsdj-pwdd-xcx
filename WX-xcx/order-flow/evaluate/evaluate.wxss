.evaluate-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 60rpx;
}

/* 冷静期提示 */
.cooling-tip {
  margin: 20rpx 24rpx;
  background-color: rgba(255, 215, 0, 0.1);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  display: flex;
  border-left: 4rpx solid #ffd700;
}

.cooling-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.cooling-content {
  flex: 1;
}

.cooling-title {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #d4a800;
  margin-bottom: 6rpx;
}

.cooling-desc {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
}

/* 星级评分 */
.section {
  margin: 20rpx 0;
}

.section-title {
  padding: 0 32rpx 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #666666;
}

.star-section {
  background-color: #ffffff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.star-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.star-row:last-child {
  border-bottom: none;
}

.star-label {
  font-size: 26rpx;
  color: #333333;
}

.star-list {
  display: flex;
  gap: 8rpx;
}

.star {
  font-size: 44rpx;
  color: #eeeeee;
  transition: color 0.2s, transform 0.2s;
}

.star.star-active {
  color: #ffd700;
  transform: scale(1.1);
}

/* 评价内容 */
.content-section {
  background-color: #ffffff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.content-input {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

.placeholder {
  color: #cccccc;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* 标签 */
.tag-section {
  background-color: #ffffff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.eval-tag {
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: #666666;
  background-color: #f5f5f5;
  border-radius: 32rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.eval-tag.tag-selected {
  color: #e94560;
  background-color: rgba(233, 69, 96, 0.08);
  border-color: #e94560;
}

/* 匿名 */
.anonymous-row {
  background-color: #ffffff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.anonymous-label {
  font-size: 28rpx;
  color: #333333;
}

/* 提交 */
.submit-section {
  padding: 32rpx 24rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #e94560, #c23152);
  border-radius: 44rpx;
  border: none;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
}

.submit-btn::after {
  border: none;
}

.submit-btn.btn-disabled {
  opacity: 0.5;
}