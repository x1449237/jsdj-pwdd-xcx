.bid-detail-page {
  min-height: 100vh;
  background: #f5f6f8;
  padding-bottom: 320rpx;
}

.order-header {
  position: relative;
  padding-bottom: 40rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 320rpx;
  background: linear-gradient(135deg, #ff6b35, #ff8f5e);
}

.order-basic {
  position: relative;
  z-index: 1;
  padding: 32rpx 24rpx 0;
}

.order-status {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.status-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.countdown {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.countdown-label {
  font-size: 22rpx;
  color: #fff;
  margin-right: 8rpx;
}

.countdown-time {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
  font-family: monospace;
}

.order-info {
  margin-bottom: 24rpx;
}

.order-game {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-bottom: 8rpx;
}

.order-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.price-row {
  display: flex;
  gap: 24rpx;
}

.price-item {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
}

.price-item.current {
  background: #fff7f5;
  border: 2rpx solid #ff6b35;
}

.price-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.price-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.current-price {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.current-price .price-symbol {
  font-size: 24rpx;
  color: #ff6b35;
  font-weight: 600;
}

.current-price .price-value {
  color: #ff6b35;
}

.section {
  margin: 24rpx;
}

.section-header {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.bid-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.empty-bids {
  padding: 60rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

.bid-list {
  margin-top: 16rpx;
}

.bid-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.bid-item:last-child {
  border-bottom: none;
}

.bid-item.winner {
  background: #fff7f5;
  margin: 0 -24rpx;
  padding: 20rpx 24rpx;
}

.bidder-info {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.bidder-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.bidder-name {
  flex: 1;
  margin-left: 16rpx;
}

.name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
}

.time {
  font-size: 22rpx;
  color: #999;
}

.winner-badge {
  background: linear-gradient(135deg, #ffd700, #ffaa00);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.bid-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.bid-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff6b35;
}

.select-btn {
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 24rpx;
  background: #ff6b35;
  color: #fff;
  font-size: 24rpx;
  border-radius: 28rpx;
  border: none;
}

.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 24rpx 40rpx;
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.05);
}

.my-bid-info {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.my-bid-label {
  font-size: 26rpx;
  color: #666;
}

.my-bid-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff6b35;
  margin-left: 8rpx;
  flex: 1;
}

.cancel-bid-btn {
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 24rpx;
  background: #f5f6f8;
  color: #666;
  font-size: 24rpx;
  border-radius: 28rpx;
  border: none;
}

.quick-btns {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.quick-btn {
  flex: 1;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  background: #f5f6f8;
  color: #666;
  font-size: 26rpx;
  border-radius: 8rpx;
}

.bid-input-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.bid-input {
  flex: 1;
  height: 80rpx;
  background: #f5f6f8;
  border-radius: 40rpx;
  padding: 0 32rpx;
  font-size: 30rpx;
  color: #333;
}

.bid-btn {
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #ff6b35, #ff8f5e);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 40rpx;
  border: none;
  padding: 0;
}

.bid-btn.disabled {
  opacity: 0.6;
}

.bid-tip {
  text-align: center;
}

.tip-text {
  font-size: 22rpx;
  color: #999;
}
