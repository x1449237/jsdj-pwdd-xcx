.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 0 60rpx;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.app-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.app-slogan {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.login-body {
  width: 100%;
}

.login-form {
  width: 100%;
}

.form-group {
  margin-bottom: 28rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 96rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.15);
  transition: border-color 0.3s;
}

.input-wrapper:focus-within {
  border-color: rgba(233, 69, 96, 0.5);
}

.input-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
  opacity: 0.6;
}

.form-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #ffffff;
  background: transparent;
}

.placeholder {
  color: rgba(255, 255, 255, 0.4);
}

.eye-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  opacity: 0.6;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #e94560, #c23152);
  border-radius: 48rpx;
  border: none;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  margin-top: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(233, 69, 96, 0.3);
}

.login-btn::after {
  border: none;
}

.login-btn.btn-disabled {
  opacity: 0.5;
}

.tips-section {
  margin-top: 48rpx;
  background-color: rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.6;
}

.login-footer {
  position: fixed;
  bottom: 60rpx;
}

.footer-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
}