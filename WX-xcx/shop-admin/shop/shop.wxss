.shop-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 140rpx;
}

.page-header {
  padding: 32rpx;
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
}

.header-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.shop-form {
  padding: 20rpx 0;
}

.form-card {
  background-color: #ffffff;
  margin: 0 24rpx 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 20rpx;
}

/* Logo */
.logo-section {
  display: flex;
  align-items: center;
}

.shop-logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background-color: #f5f5f5;
}

.logo-tip {
  margin-left: 24rpx;
}

.tip-text {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 6rpx;
}

.tip-sub {
  font-size: 22rpx;
  color: #999999;
}

/* Banner */
.banner-section {
  position: relative;
}

.shop-banner {
  width: 100%;
  height: 240rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
}

.banner-tip {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: 8rpx;
  padding: 6rpx 16rpx;
}

.banner-tip .tip-text {
  color: #ffffff;
  font-size: 22rpx;
}

.banner-tip .tip-sub {
  color: rgba(255, 255, 255, 0.7);
  font-size: 20rpx;
}

/* 输入框 */
.input-section {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
}

.text-input {
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
  color: #333333;
}

.placeholder {
  color: #cccccc;
}

.char-count {
  font-size: 22rpx;
  color: #999999;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* 文本域 */
.textarea-section {
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}

.text-area {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

/* 颜色选择器 */
.color-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.color-item {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid transparent;
  transition: all 0.2s;
}

.color-item.color-selected {
  border-color: #333333;
  transform: scale(1.1);
}

.check-mark {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: bold;
}

/* 底部保存栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 10;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #e94560, #c23152);
  border-radius: 44rpx;
  border: none;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
}

.save-btn::after {
  border: none;
}

.save-btn.btn-disabled {
  opacity: 0.5;
}