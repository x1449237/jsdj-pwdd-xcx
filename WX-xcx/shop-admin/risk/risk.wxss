.risk-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

.page-header {
  padding: 32rpx;
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
}

.header-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 筛选栏 */
.filter-bar {
  background-color: #ffffff;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #eeeeee;
}

.filter-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.filter-row:last-child {
  margin-bottom: 0;
}

.filter-label {
  font-size: 26rpx;
  color: #333333;
  flex-shrink: 0;
  margin-top: 8rpx;
  margin-right: 16rpx;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  flex: 1;
}

.filter-tag {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  color: #666666;
  background-color: #f5f5f5;
  border-radius: 32rpx;
  border: 2rpx solid transparent;
}

.filter-tag.tag-active {
  color: #e94560;
  background-color: rgba(233, 69, 96, 0.08);
  border-color: #e94560;
}

/* 风险用户列表 */
.risk-list {
  padding: 16rpx 24rpx;
}

.risk-user-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.user-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
  margin-right: 16rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 4rpx;
}

.user-id {
  font-size: 22rpx;
  color: #999999;
}

.risk-level-badge {
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  border-radius: 4rpx;
  font-weight: 500;
}

.level-high {
  background-color: rgba(233, 69, 96, 0.1);
  color: #e94560;
}

.level-medium {
  background-color: rgba(255, 151, 106, 0.1);
  color: #ff976a;
}

.level-low {
  background-color: rgba(255, 215, 0, 0.15);
  color: #d4a800;
}

.user-body {
  padding: 16rpx 0;
  border-top: 1rpx solid #f5f5f5;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row {
  display: flex;
  margin-bottom: 10rpx;
  font-size: 26rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.row-label {
  color: #999999;
  flex-shrink: 0;
}

.row-value {
  color: #333333;
  flex: 1;
}

.risk-reason {
  line-height: 1.5;
}

.user-footer {
  padding-top: 16rpx;
  display: flex;
}

.remark-label {
  font-size: 24rpx;
  color: #999999;
  flex-shrink: 0;
}

.remark-text {
  font-size: 24rpx;
  color: #666666;
  flex: 1;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-state-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-state-text {
  font-size: 28rpx;
  color: #999999;
}

.loading-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.loading-more {
  text-align: center;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: #999999;
}

.no-more {
  text-align: center;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: #cccccc;
}