<view class="orders-page">
  <!-- 顶部Tab切换 -->
  <view class="tab-bar">
    <view
      class="tab-item {{currentTab === 'all' ? 'tab-active' : ''}}"
      bindtap="onTabChange"
      data-tab="all"
    >
      本店订单
    </view>
    <view
      class="tab-item {{currentTab === 'risk' ? 'tab-active' : ''}}"
      bindtap="onTabChange"
      data-tab="risk"
    >
      大额验证失败
    </view>
  </view>

  <!-- 状态筛选栏 -->
  <view class="filter-bar">
    <scroll-view scroll-x class="filter-scroll">
      <view
        class="filter-item {{currentStatus === -1 ? 'filter-active' : ''}}"
        bindtap="onStatusFilter"
        data-status="{{-1}}"
      >
        全部
      </view>
      <view
        wx:for="{{statusList}}"
        wx:key="value"
        class="filter-item {{currentStatus === item.value ? 'filter-active' : ''}}"
        bindtap="onStatusFilter"
        data-status="{{item.value}}"
      >
        {{item.label}}
      </view>
    </scroll-view>
  </view>

  <!-- 本店订单列表 -->
  <view class="order-list" wx:if="{{currentTab === 'all'}}">
    <block wx:if="{{orderList.length > 0}}">
      <view
        class="order-card"
        wx:for="{{orderList}}"
        wx:key="order_id"
      >
        <view class="order-header">
          <text class="order-id">订单号：{{item.order_id}}</text>
          <text class="order-status" style="color: {{item.statusColor}}">{{item.statusText}}</text>
        </view>

        <view class="order-body">
          <view class="order-info-row">
            <text class="info-label">游戏：</text>
            <text class="info-value">{{item.game_name}}</text>
          </view>
          <view class="order-info-row">
            <text class="info-label">服务：</text>
            <text class="info-value">{{item.service_name}}</text>
          </view>
          <view class="order-info-row">
            <text class="info-label">金额：</text>
            <text class="info-value text-primary font-bold">¥{{item.amount}}</text>
          </view>
          <view class="order-info-row">
            <text class="info-label">打手：</text>
            <text class="info-value">{{item.player_name}}</text>
          </view>
          <view class="order-info-row">
            <text class="info-label">时间：</text>
            <text class="info-value">{{item.create_time}}</text>
          </view>
        </view>

        <view class="order-actions">
          <button
            wx:if="{{item.status === 0}}"
            class="action-btn action-online"
            bindtap="onToggleOnline"
            data-order="{{item}}"
            data-action="online"
          >
            上架
          </button>
          <button
            wx:if="{{item.status === 0}}"
            class="action-btn action-offline"
            bindtap="onToggleOnline"
            data-order="{{item}}"
            data-action="offline"
          >
            下架
          </button>
          <button
            class="action-btn action-detail"
            bindtap="onViewDetail"
            data-order-id="{{item.order_id}}"
          >
            查看详情
          </button>
        </view>
      </view>
    </block>

    <view class="empty-state" wx:if="{{orderList.length === 0 && !loading}}">
      <text class="empty-state-text">暂无订单</text>
    </view>

    <view class="loading-wrapper" wx:if="{{loading}}">
      <text class="loading-more">加载中...</text>
    </view>

    <view class="no-more" wx:if="{{!hasMore && orderList.length > 0}}">
      <text>— 没有更多了 —</text>
    </view>
  </view>

  <!-- 大额验证失败Tab -->
  <view class="risk-list" wx:if="{{currentTab === 'risk'}}">
    <block wx:if="{{riskOrderList.length > 0}}">
      <view
        class="risk-card"
        wx:for="{{riskOrderList}}"
        wx:key="order_id"
      >
        <view class="risk-card-header">
          <view class="risk-badge">验证失败</view>
          <text class="order-id">{{item.order_id}}</text>
        </view>

        <view class="order-body">
          <view class="order-info-row">
            <text class="info-label">金额：</text>
            <text class="info-value text-danger font-bold">¥{{item.amount}}</text>
          </view>
          <view class="order-info-row">
            <text class="info-label">用户：</text>
            <text class="info-value">{{item.user_name}}</text>
          </view>
          <view class="order-info-row">
            <text class="info-label">失败原因：</text>
            <text class="info-value text-danger">{{item.fail_reason}}</text>
          </view>
          <view class="order-info-row">
            <text class="info-label">时间：</text>
            <text class="info-value">{{item.create_time}}</text>
          </view>
        </view>
      </view>
    </block>

    <view class="empty-state" wx:if="{{riskOrderList.length === 0 && !riskLoading}}">
      <text class="empty-state-text">暂无大额验证失败订单</text>
    </view>

    <view class="loading-wrapper" wx:if="{{riskLoading}}">
      <text class="loading-more">加载中...</text>
    </view>
  </view>
</view>