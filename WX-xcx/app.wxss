/* ========== CSS 变量定义 ========== */
page {
  --color-primary: #e94560;
  --color-primary-dark: #c23152;
  --color-primary-light: #ff6b81;
  --color-secondary: #0f3460;
  --color-bg: #f5f5f5;
  --color-bg-white: #ffffff;
  --color-bg-dark: #1a1a2e;
  --color-text-primary: #333333;
  --color-text-secondary: #666666;
  --color-text-tip: #999999;
  --color-text-white: #ffffff;
  --color-border: #eeeeee;
  --color-success: #07c160;
  --color-warning: #ff976a;
  --color-danger: #e94560;
  --color-gold: #ffd700;

  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;

  --font-size-xs: 22rpx;
  --font-size-sm: 24rpx;
  --font-size-md: 28rpx;
  --font-size-lg: 32rpx;
  --font-size-xl: 36rpx;
  --font-size-xxl: 44rpx;

  --border-radius-sm: 8rpx;
  --border-radius-md: 12rpx;
  --border-radius-lg: 16rpx;
  --border-radius-round: 50%;

  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);

  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: var(--color-text-primary);
  background-color: var(--color-bg);
  box-sizing: border-box;
}

/* ========== 通用工具类 ========== */

/* Flex 布局 */
.flex {
  display: flex;
}
.flex-col {
  display: flex;
  flex-direction: column;
}
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}
.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.flex-wrap {
  flex-wrap: wrap;
}
.flex-1 {
  flex: 1;
}
.align-center {
  align-items: center;
}
.justify-center {
  justify-content: center;
}
.justify-end {
  justify-content: flex-end;
}

/* 文字对齐 */
.text-left { text-align: left; }
.text-center { text-align: center; }
.text-right { text-align: right; }

/* 文字颜色 */
.text-primary { color: var(--color-primary); }
.text-secondary { color: var(--color-text-secondary); }
.text-tip { color: var(--color-text-tip); }
.text-white { color: var(--color-text-white); }
.text-success { color: var(--color-success); }
.text-warning { color: var(--color-warning); }
.text-danger { color: var(--color-danger); }

/* 文字大小 */
.text-xs { font-size: var(--font-size-xs); }
.text-sm { font-size: var(--font-size-sm); }
.text-md { font-size: var(--font-size-md); }
.text-lg { font-size: var(--font-size-lg); }
.text-xl { font-size: var(--font-size-xl); }
.text-xxl { font-size: var(--font-size-xxl); }

/* 文字粗细 */
.font-bold { font-weight: bold; }
.font-normal { font-weight: normal; }

/* 文字溢出 */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.text-ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

/* 间距 */
.mt-xs { margin-top: var(--spacing-xs); }
.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }
.mt-xl { margin-top: var(--spacing-xl); }
.mb-xs { margin-bottom: var(--spacing-xs); }
.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }
.mb-lg { margin-bottom: var(--spacing-lg); }
.mb-xl { margin-bottom: var(--spacing-xl); }
.ml-sm { margin-left: var(--spacing-sm); }
.ml-md { margin-left: var(--spacing-md); }
.mr-sm { margin-right: var(--spacing-sm); }
.mr-md { margin-right: var(--spacing-md); }

.pt-sm { padding-top: var(--spacing-sm); }
.pt-md { padding-top: var(--spacing-md); }
.pt-lg { padding-top: var(--spacing-lg); }
.pb-sm { padding-bottom: var(--spacing-sm); }
.pb-md { padding-bottom: var(--spacing-md); }
.pb-lg { padding-bottom: var(--spacing-lg); }
.pl-md { padding-left: var(--spacing-md); }
.pl-lg { padding-left: var(--spacing-lg); }
.pr-md { padding-right: var(--spacing-md); }
.pr-lg { padding-right: var(--spacing-lg); }
.p-sm { padding: var(--spacing-sm); }
.p-md { padding: var(--spacing-md); }
.p-lg { padding: var(--spacing-lg); }

/* 背景 */
.bg-white { background-color: var(--color-bg-white); }
.bg-primary { background-color: var(--color-primary); }
.bg-dark { background-color: var(--color-bg-dark); }

/* 圆角 */
.radius-sm { border-radius: var(--border-radius-sm); }
.radius-md { border-radius: var(--border-radius-md); }
.radius-lg { border-radius: var(--border-radius-lg); }
.radius-round { border-radius: var(--border-radius-round); }

/* 阴影 */
.shadow-sm { box-shadow: var(--shadow-sm); }
.shadow-md { box-shadow: var(--shadow-md); }

/* 隐藏 */
.hidden { display: none !important; }

/* 分割线 */
.divider {
  width: 100%;
  height: 1rpx;
  background-color: var(--color-border);
}

/* 安全区域 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========== 按钮样式 ========== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: var(--border-radius-md);
  font-size: var(--font-size-lg);
  border: none;
  outline: none;
  transition: opacity 0.2s;
}
.btn::after {
  border: none;
}
.btn:active {
  opacity: 0.8;
}

.btn-primary {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  color: var(--color-text-white);
}

.btn-secondary {
  background-color: var(--color-secondary);
  color: var(--color-text-white);
}

.btn-outline {
  background-color: transparent;
  border: 2rpx solid var(--color-primary);
  color: var(--color-primary);
}

.btn-ghost {
  background-color: transparent;
  color: var(--color-text-primary);
}

.btn-danger {
  background-color: var(--color-danger);
  color: var(--color-text-white);
}

.btn-sm {
  height: 60rpx;
  padding: 0 var(--spacing-md);
  font-size: var(--font-size-sm);
  border-radius: var(--border-radius-sm);
}

.btn-block {
  width: 100%;
}

.btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* ========== 卡片样式 ========== */
.card {
  background-color: var(--color-bg-white);
  border-radius: var(--border-radius-md);
  padding: var(--spacing-md);
  margin: var(--spacing-sm) var(--spacing-md);
  box-shadow: var(--shadow-sm);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: var(--spacing-sm);
  border-bottom: 1rpx solid var(--color-border);
}

.card-body {
  padding: var(--spacing-sm) 0;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-top: var(--spacing-sm);
  border-top: 1rpx solid var(--color-border);
}

/* ========== 表单样式 ========== */
.form-group {
  margin-bottom: var(--spacing-md);
}

.form-label {
  display: block;
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-xs);
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 var(--spacing-md);
  background-color: var(--color-bg);
  border-radius: var(--border-radius-sm);
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: var(--spacing-sm) var(--spacing-md);
  background-color: var(--color-bg);
  border-radius: var(--border-radius-sm);
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  box-sizing: border-box;
}

.form-placeholder {
  color: var(--color-text-tip);
}

.form-error {
  font-size: var(--font-size-xs);
  color: var(--color-danger);
  margin-top: var(--spacing-xs);
}

.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 96rpx;
  padding: 0 var(--spacing-md);
  background-color: var(--color-bg-white);
  border-bottom: 1rpx solid var(--color-border);
}

.form-item-label {
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  flex-shrink: 0;
  margin-right: var(--spacing-md);
}

.form-item-value {
  flex: 1;
  text-align: right;
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
}

.form-item-arrow {
  width: 32rpx;
  height: 32rpx;
  margin-left: var(--spacing-sm);
}

/* ========== 标签/徽章 ========== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  font-size: var(--font-size-xs);
  border-radius: 4rpx;
  margin-right: 8rpx;
}

.tag-primary {
  background-color: rgba(233, 69, 96, 0.1);
  color: var(--color-primary);
}

.tag-success {
  background-color: rgba(7, 193, 96, 0.1);
  color: var(--color-success);
}

.tag-warning {
  background-color: rgba(255, 151, 106, 0.1);
  color: var(--color-warning);
}

.tag-gold {
  background-color: rgba(255, 215, 0, 0.15);
  color: var(--color-gold);
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-state-image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: var(--spacing-md);
}

.empty-state-text {
  font-size: var(--font-size-md);
  color: var(--color-text-tip);
}

/* ========== 加载状态 ========== */
.loading-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.loading-more {
  text-align: center;
  padding: 20rpx 0;
  font-size: var(--font-size-sm);
  color: var(--color-text-tip);
}

.no-more {
  text-align: center;
  padding: 20rpx 0;
  font-size: var(--font-size-sm);
  color: var(--color-text-tip);
}