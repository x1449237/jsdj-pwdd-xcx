<view class="group-room-page">
  <!-- 顶部状态栏 -->
  <view class="chat-header">
    <view class="header-back" bindtap="onBack">
      <text class="back-icon">‹</text>
    </view>
    <view class="header-info" bindtap="onTapGroupName">
      <text class="header-name">{{groupName}}</text>
      <text class="header-type">{{groupTypeLabel}}</text>
    </view>
    <view class="header-more" bindtap="onMore">
      <text class="more-icon">⋯</text>
    </view>
  </view>

  <!-- 群信息面板 -->
  <view class="group-info-panel" wx:if="{{showGroupInfo}}">
    <view class="info-panel-header">
      <text class="panel-title">群信息</text>
      <view class="panel-close" bindtap="onHideGroupInfo">
        <text>✕</text>
      </view>
    </view>

    <view class="info-section">
      <text class="section-title">群公告</text>
      <view class="announcement-content" wx:if="{{announcement}}">
        <text>{{announcement}}</text>
      </view>
      <view class="announcement-empty" wx:else>
        <text>暂无群公告</text>
      </view>
      <view class="announcement-edit" wx:if="{{isAdmin || isCreator}}" bindtap="onEditAnnouncement">
        <text>编辑公告</text>
      </view>
    </view>

    <view class="info-section">
      <text class="section-title">群成员 ({{memberList.length}})</text>
      <view class="member-list">
        <view
          wx:for="{{memberList}}"
          wx:key="user_id"
          class="member-item"
          bindtap="onMemberAction"
          data-member="{{item}}"
        >
          <image class="member-avatar" src="{{item.avatar}}" mode="aspectFill"></image>
          <view class="member-info">
            <view class="member-name-row">
              <text class="member-name">{{item.nickname}}</text>
              <view class="v-badge" wx:if="{{item.is_platform_official}}">
                <text class="v-badge-text v-badge-golden">V</text>
              </view>
            </view>
            <text class="member-role" wx:if="{{item.is_creator}}">群主</text>
            <text class="member-role" wx:elif="{{item.is_admin}}">管理员</text>
          </view>
          <view class="member-actions" wx:if="{{(isAdmin || isCreator) && item.user_id !== myUserId}}">
            <text class="action-icon">⋮</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 消息列表 -->
  <scroll-view
    class="message-list"
    scroll-y
    scroll-with-animation
    scroll-into-view="{{scrollToView}}"
    enable-back-to-top
    bindscrolltoupper="onLoadMore"
    upper-threshold="100"
  >
    <view class="loading-history" wx:if="{{loadingMore}}">
      <text>加载中...</text>
    </view>
    <view class="no-more-history" wx:if="{{!hasMoreHistory && messageList.length > 0}}">
      <text>— 以上是历史消息 —</text>
    </view>

    <view
      wx:for="{{messageList}}"
      wx:key="msg_id"
      id="msg-{{item.msg_id}}"
      class="message-item {{item.from_self ? 'message-self' : 'message-other'}}"
    >
      <!-- 系统消息 / 群公告 -->
      <view class="system-message" wx:if="{{item.type === 'system' || item.type === 'announcement'}}">
        <text class="system-text">{{item.type === 'announcement' ? '📢 ' : ''}}{{item.content}}</text>
      </view>

      <!-- 普通消息 -->
      <block wx:if="{{item.type !== 'system' && item.type !== 'announcement'}}">
        <image
          wx:if="{{!item.from_self}}"
          class="msg-avatar"
          src="{{item.avatar}}"
          mode="aspectFill"
        ></image>

        <view class="msg-content-wrapper">
          <!-- 发送者昵称和标识 -->
          <view class="msg-sender" wx:if="{{!item.from_self}}">
            <text class="sender-name">{{item.nickname}}</text>
            <view class="v-badge" wx:if="{{item.is_platform_official}}">
              <text class="v-badge-text v-badge-golden">V</text>
            </view>
            <text class="platform-tag" wx:if="{{item.is_platform_official}}">【平台官方】</text>
          </view>

          <!-- 文字消息 -->
          <view
            wx:if="{{item.type === 'text'}}"
            class="msg-bubble msg-text {{item.from_self ? 'bubble-self' : 'bubble-other'}}"
            bindlongpress="onLongPressMessage"
            data-msg="{{item}}"
          >
            <text>{{item.content}}</text>
          </view>

          <!-- 图片消息 -->
          <view
            wx:if="{{item.type === 'image'}}"
            class="msg-bubble msg-image {{item.from_self ? 'bubble-self' : 'bubble-other'}}"
            bindtap="onPreviewImage"
            data-url="{{item.image_url}}"
          >
            <image
              class="msg-img"
              src="{{item.image_url}}"
              mode="widthFix"
            ></image>
          </view>

          <!-- 语音消息 -->
          <view
            wx:if="{{item.type === 'voice'}}"
            class="msg-bubble msg-voice {{item.from_self ? 'bubble-self' : 'bubble-other'}}"
            bindtap="onPlayVoice"
            bindlongpress="onLongPressMessage"
            data-msg="{{item}}"
          >
            <text class="voice-icon">{{item.playing ? '🔊' : '🔈'}}</text>
            <text class="voice-duration">{{item.duration}}"</text>
          </view>

          <!-- 文件消息 -->
          <view
            wx:if="{{item.type === 'file'}}"
            class="msg-bubble msg-file {{item.from_self ? 'bubble-self' : 'bubble-other'}}"
            bindtap="onOpenFile"
            bindlongpress="onLongPressMessage"
            data-msg="{{item}}"
          >
            <view class="file-icon">📄</view>
            <view class="file-info">
              <text class="file-name">{{item.file_name}}</text>
              <text class="file-size">{{item.file_size_text}}</text>
            </view>
          </view>

          <!-- 撤回消息 -->
          <view
            wx:if="{{item.type === 'recall'}}"
            class="msg-bubble msg-recall"
          >
            <text class="recall-text">{{item.from_self ? '你撤回了一条消息' : '对方撤回了一条消息'}}</text>
          </view>

          <!-- 敏感词拦截提示 -->
          <view wx:if="{{item.sensitive_blocked}}" class="sensitive-tip">
            <text>⚠️ 消息含有敏感词，发送失败</text>
          </view>

          <!-- 飞单风险提示 -->
          <view wx:if="{{item.anti_fraud_risky && item.from_self}}" class="anti-fraud-tip">
            <text>⚠️ 检测到风险内容，已自动屏蔽</text>
          </view>
        </view>

        <image
          wx:if="{{item.from_self}}"
          class="msg-avatar"
          src="{{myAvatar}}"
          mode="aspectFill"
        ></image>
      </block>
    </view>
  </scroll-view>

  <!-- 底部输入栏 -->
  <view class="input-bar">
    <view class="voice-mode" wx:if="{{inputMode === 'voice'}}">
      <view
        class="voice-btn"
        bindtouchstart="onVoiceStart"
        bindtouchmove="onVoiceMove"
        bindtouchend="onVoiceEnd"
      >
        <text class="voice-btn-text">{{recording ? '松开 发送' : '按住 说话'}}</text>
      </view>
    </view>

    <view class="text-mode" wx:else>
      <view class="mode-switch" bindtap="onSwitchMode">
        <text class="switch-icon">🎤</text>
      </view>
      <view class="input-wrapper">
        <input
          class="text-input"
          type="text"
          placeholder="输入消息..."
          placeholder-class="input-placeholder"
          value="{{inputText}}"
          bindinput="onTextInput"
          bindconfirm="onSendText"
          confirm-type="send"
          adjust-position="{{false}}"
          cursor-spacing="20"
        />
      </view>
      <view class="image-btn" bindtap="onChooseImage">
        <text class="image-icon">🖼</text>
      </view>
    </view>

    <view class="send-btn" wx:if="{{inputText.length > 0 && inputMode === 'text'}}" bindtap="onSendText">
      <text class="send-text">发送</text>
    </view>
  </view>

  <!-- 语音录制浮层 -->
  <view class="voice-overlay" wx:if="{{recording}}">
    <view class="voice-overlay-content">
      <view class="voice-wave">
        <view class="wave-bar" wx:for="{{[1,2,3,4,5,6,7]}}" wx:key="*this" style="animation-delay: {{item * 0.1}}s;"></view>
      </view>
      <text class="voice-overlay-tip {{willCancel ? 'cancel-tip' : ''}}">
        {{willCancel ? '松开手指，取消发送' : '手指上滑，取消发送'}}
      </text>
    </view>
  </view>

  <!-- 更多操作面板 -->
  <view class="more-panel" wx:if="{{showMorePanel}}">
    <view class="panel-item" bindtap="onChooseImage">
      <view class="panel-icon">📷</view>
      <text class="panel-label">相册</text>
    </view>
    <view class="panel-item" bindtap="onTakePhoto">
      <view class="panel-icon">📸</view>
      <text class="panel-label">拍照</text>
    </view>
    <view class="panel-item" bindtap="onChooseFile">
      <view class="panel-icon">📄</view>
      <text class="panel-label">文件</text>
    </view>
    <view class="panel-item" bindtap="onSwitchMode">
      <view class="panel-icon">🎤</view>
      <text class="panel-label">语音</text>
    </view>
    <view class="panel-item" wx:if="{{isAdmin || isCreator}}" bindtap="onManageAnnouncement">
      <view class="panel-icon">📢</view>
      <text class="panel-label">定时公告</text>
    </view>
  </view>

  <!-- 公告编辑弹窗 -->
  <view class="modal-mask" wx:if="{{showAnnouncementModal}}" bindtap="onCancelAnnouncement"></view>
  <view class="announcement-modal" wx:if="{{showAnnouncementModal}}">
    <view class="modal-header">
      <text class="modal-title">编辑群公告</text>
      <view class="modal-close" bindtap="onCancelAnnouncement">
        <text>✕</text>
      </view>
    </view>
    <view class="modal-body">
      <textarea
        class="announcement-textarea"
        placeholder="请输入群公告内容"
        placeholder-class="form-placeholder"
        value="{{editAnnouncementText}}"
        bindinput="onAnnouncementInput"
        maxlength="500"
        auto-height
      />
    </view>
    <view class="modal-footer">
      <view class="btn-cancel" bindtap="onCancelAnnouncement">
        <text>取消</text>
      </view>
      <view class="btn-confirm" bindtap="onSaveAnnouncement">
        <text>保存</text>
      </view>
    </view>
  </view>

  <!-- 定时公告管理面板 -->
  <view class="modal-mask" wx:if="{{showSchedulePanel}}" bindtap="onCloseSchedulePanel"></view>
  <view class="schedule-panel" wx:if="{{showSchedulePanel}}">
    <view class="panel-header">
      <text class="panel-title">定时公告管理</text>
      <view class="panel-close" bindtap="onCloseSchedulePanel">×</view>
    </view>

    <view class="schedule-form">
      <view class="form-item">
        <text class="form-label">公告标题</text>
        <input class="form-input" placeholder="请输入公告标题" value="{{scheduleTitle}}" bindinput="onScheduleTitleInput" />
      </view>
      <view class="form-item">
        <text class="form-label">公告内容</text>
        <textarea class="form-textarea" placeholder="请输入公告内容" value="{{scheduleContent}}" bindinput="onScheduleContentInput" auto-height maxlength="500"></textarea>
      </view>
      <view class="form-item">
        <text class="form-label">发送时间</text>
        <picker mode="date" value="{{scheduleDate}}" bindchange="onScheduleDateChange">
          <view class="picker-view">{{scheduleDate || '选择日期'}}</view>
        </picker>
        <picker mode="time" value="{{scheduleTime}}" bindchange="onScheduleTimeChange">
          <view class="picker-view">{{scheduleTime || '选择时间'}}</view>
        </picker>
      </view>
      <view class="schedule-btn" bindtap="onCreateSchedule">
        <text>创建定时公告</text>
      </view>
    </view>

    <view class="schedule-list-title">
      <text>待发送公告</text>
    </view>
    <scroll-view class="schedule-list" scroll-y>
      <view class="schedule-item" wx:for="{{scheduleList}}" wx:key="id">
        <view class="schedule-item-header">
          <text class="schedule-item-title">{{item.title}}</text>
          <text class="schedule-item-status {{item.is_sent ? 'sent' : 'pending'}}">{{item.is_sent ? '已发送' : '待发送'}}</text>
        </view>
        <view class="schedule-item-content">{{item.content}}</view>
        <view class="schedule-item-time">
          <text>发送时间：{{item.schedule_time}}</text>
        </view>
        <view class="schedule-item-actions" wx:if="{{!item.is_sent}}">
          <text class="action-text delete" bindtap="onDeleteSchedule" data-id="{{item.id}}">删除</text>
        </view>
      </view>
      <view class="schedule-empty" wx:if="{{scheduleList.length === 0}}">
        <text>暂无定时公告</text>
      </view>
    </scroll-view>
  </view>

  <!-- 飞单风控警告弹窗 -->
  <view class="modal-mask" wx:if="{{showAntiFraudModal}}" bindtap="onCloseAntiFraudModal"></view>
  <view class="anti-fraud-modal" wx:if="{{showAntiFraudModal}}">
    <view class="modal-icon">⚠️</view>
    <view class="modal-title">风险提示</view>
    <view class="modal-content">
      <text>{{antiFraudModalContent}}</text>
    </view>
    <view class="modal-btn" bindtap="onCloseAntiFraudModal">
      <text>我知道了</text>
    </view>
  </view>
</view>