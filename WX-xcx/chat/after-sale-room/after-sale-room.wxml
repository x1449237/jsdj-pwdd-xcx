<view class="after-sale-room-page">
  <!-- 顶部状态栏 -->
  <view class="chat-header">
    <view class="header-back" bindtap="onBack">
      <text class="back-icon">‹</text>
    </view>
    <view class="header-info">
      <text class="header-name">售后会话</text>
      <text class="header-order">{{orderSn}}</text>
    </view>
    <view class="header-more" bindtap="onMore">
      <text class="more-icon">⋯</text>
    </view>
  </view>

  <!-- 介入警示横幅（客服端） -->
  <view class="intervene-banner" wx:if="{{showInterveneBanner}}">
    <text class="intervene-banner-icon">⚠️</text>
    <text class="intervene-banner-text">{{interveneBannerText}}</text>
  </view>

  <!-- 申请平台介入按钮 + 举证上传 -->
  <view class="intervene-toolbar" wx:if="{{interveneStatus !== 2}}">
    <view class="intervene-btn {{interveneStatus === 1 ? 'intervene-btn-disabled' : ''}}" bindtap="onRequestIntervene">
      <text class="intervene-btn-text">{{interveneStatus === 1 ? '平台已介入' : '申请平台介入'}}</text>
    </view>
    <view class="evidence-btn" bindtap="onUploadEvidence">
      <text class="evidence-btn-text">📎 举证上传</text>
    </view>
    <view class="arbitration-btn" bindtap="onApplyArbitration">
      <text class="arbitration-btn-text">申请仲裁</text>
    </view>
  </view>

  <!-- 消息列表 -->
  <scroll-view
    class="message-list"
    scroll-y
    scroll-with-animation
    scroll-into-view="{{scrollToView}}"
    enable-back-to-top
    bindscrolltoupper="onLoadMore"
    upper-threshold="100"
  >
    <view class="loading-history" wx:if="{{loadingMore}}">
      <text>加载中...</text>
    </view>
    <view class="no-more-history" wx:if="{{!hasMoreHistory && messageList.length > 0}}">
      <text>— 以上是历史消息 —</text>
    </view>

    <view
      wx:for="{{messageList}}"
      wx:key="msg_id"
      id="msg-{{item.msg_id}}"
      class="message-item {{item.from_self ? 'message-self' : 'message-other'}}"
    >
      <!-- 系统消息 -->
      <view class="system-message" wx:if="{{item.type === 'system'}}">
        <text class="system-text">{{item.content}}</text>
      </view>

      <!-- 普通消息 -->
      <block wx:if="{{item.type !== 'system'}}">
        <image
          wx:if="{{!item.from_self}}"
          class="msg-avatar"
          src="{{item.avatar}}"
          mode="aspectFill"
        ></image>

        <view class="msg-content-wrapper">
          <!-- 发送者昵称和标识 -->
          <view class="msg-sender" wx:if="{{!item.from_self}}">
            <text class="sender-name">{{item.nickname}}</text>
            <view class="v-badge" wx:if="{{item.is_platform_official}}">
              <text class="v-badge-text v-badge-golden">V</text>
            </view>
            <text class="platform-tag" wx:if="{{item.is_platform_official}}">【平台官方】</text>
          </view>

          <!-- 文字消息 -->
          <view
            wx:if="{{item.type === 'text'}}"
            class="msg-bubble msg-text {{item.from_self ? 'bubble-self' : 'bubble-other'}}"
            bindlongpress="onLongPressMessage"
            data-msg="{{item}}"
          >
            <text>{{item.content}}</text>
          </view>

          <!-- 图片消息 -->
          <view
            wx:if="{{item.type === 'image'}}"
            class="msg-bubble msg-image {{item.from_self ? 'bubble-self' : 'bubble-other'}}"
            bindtap="onPreviewImage"
            data-url="{{item.image_url}}"
          >
            <image
              class="msg-img"
              src="{{item.image_url}}"
              mode="widthFix"
            ></image>
          </view>

          <!-- 语音消息 -->
          <view
            wx:if="{{item.type === 'voice'}}"
            class="msg-bubble msg-voice-wrap {{item.from_self ? 'bubble-self' : 'bubble-other'}}"
            bindlongpress="onLongPressMessage"
            data-msg="{{item}}"
          >
            <view class="msg-voice" bindtap="onPlayVoice" data-msg="{{item}}">
              <text class="voice-icon">{{item.playing ? '🔊' : '🔈'}}</text>
              <text class="voice-duration">{{item.duration}}"</text>
            </view>
            <view class="voice-asr" wx:if="{{item.asr_text}}" bindtap="onToggleAsr" data-msg="{{item}}">
              <text class="asr-toggle">{{item.show_asr ? '收起' : '转文字'}}</text>
            </view>
            <view class="asr-content" wx:if="{{item.show_asr && item.asr_text}}">
              <text>{{item.asr_text}}</text>
            </view>
          </view>

          <!-- 文件消息 -->
          <view
            wx:if="{{item.type === 'file'}}"
            class="msg-bubble msg-file {{item.from_self ? 'bubble-self' : 'bubble-other'}}"
            bindtap="onOpenFile"
            bindlongpress="onLongPressMessage"
            data-msg="{{item}}"
          >
            <view class="file-icon">📄</view>
            <view class="file-info">
              <text class="file-name">{{item.file_name}}</text>
              <text class="file-size">{{item.file_size_text}}</text>
            </view>
          </view>

          <!-- 撤回消息 -->
          <view
            wx:if="{{item.type === 'recall'}}"
            class="msg-bubble msg-recall"
          >
            <text class="recall-text">{{item.from_self ? '你撤回了一条消息' : '对方撤回了一条消息'}}</text>
          </view>

          <!-- 敏感词拦截提示 -->
          <view wx:if="{{item.sensitive_blocked}}" class="sensitive-tip">
            <text>⚠️ 消息含有敏感词，发送失败</text>
          </view>

          <!-- 飞单风险提示 -->
          <view wx:if="{{item.anti_fraud_risky && item.from_self}}" class="anti-fraud-tip">
            <text>⚠️ 检测到风险内容，已自动屏蔽</text>
          </view>
        </view>

        <image
          wx:if="{{item.from_self}}"
          class="msg-avatar"
          src="{{myAvatar}}"
          mode="aspectFill"
        ></image>
      </block>
    </view>
  </scroll-view>

  <!-- 底部输入栏 -->
  <view class="input-bar">
    <view class="voice-mode" wx:if="{{inputMode === 'voice'}}">
      <view
        class="voice-btn"
        bindtouchstart="onVoiceStart"
        bindtouchmove="onVoiceMove"
        bindtouchend="onVoiceEnd"
      >
        <text class="voice-btn-text">{{recording ? '松开 发送' : '按住 说话'}}</text>
      </view>
    </view>

    <view class="text-mode" wx:else>
      <view class="mode-switch" bindtap="onSwitchMode">
        <text class="switch-icon">🎤</text>
      </view>
      <view class="input-wrapper">
        <input
          class="text-input"
          type="text"
          placeholder="输入消息..."
          placeholder-class="input-placeholder"
          value="{{inputText}}"
          bindinput="onTextInput"
          bindconfirm="onSendText"
          confirm-type="send"
          adjust-position="{{false}}"
          cursor-spacing="20"
        />
      </view>
      <view class="image-btn" bindtap="onChooseImage">
        <text class="image-icon">🖼</text>
      </view>
    </view>

    <view class="send-btn" wx:if="{{inputText.length > 0 && inputMode === 'text'}}" bindtap="onSendText">
      <text class="send-text">发送</text>
    </view>
  </view>

  <!-- 语音录制浮层 -->
  <view class="voice-overlay" wx:if="{{recording}}">
    <view class="voice-overlay-content">
      <view class="voice-wave">
        <view class="wave-bar" wx:for="{{[1,2,3,4,5,6,7]}}" wx:key="*this" style="animation-delay: {{item * 0.1}}s;"></view>
      </view>
      <text class="voice-overlay-tip {{willCancel ? 'cancel-tip' : ''}}">
        {{willCancel ? '松开手指，取消发送' : '手指上滑，取消发送'}}
      </text>
    </view>
  </view>

  <!-- 更多操作面板 -->
  <view class="more-panel" wx:if="{{showMorePanel}}">
    <view class="panel-item" bindtap="onChooseImage">
      <view class="panel-icon">📷</view>
      <text class="panel-label">相册</text>
    </view>
    <view class="panel-item" bindtap="onTakePhoto">
      <view class="panel-icon">📸</view>
      <text class="panel-label">拍照</text>
    </view>
    <view class="panel-item" bindtap="onChooseFile">
      <view class="panel-icon">📄</view>
      <text class="panel-label">文件</text>
    </view>
    <view class="panel-item" bindtap="onUploadEvidence">
      <view class="panel-icon">📎</view>
      <text class="panel-label">举证上传</text>
    </view>
    <view class="panel-item" bindtap="onSwitchMode">
      <view class="panel-icon">🎤</view>
      <text class="panel-label">语音</text>
    </view>
  </view>

  <subscribe-msg 
    id="subscribeMsg"
    tmplIds="{{subscribeTmplIds}}"
    scene="after_sale"
    auto="{{true}}"
    bind:subscribed="onSubscribeResult">
  </subscribe-msg>

  <!-- 举证上传弹窗 -->
  <view class="modal-mask" wx:if="{{showEvidenceModal}}" bindtap="onCloseEvidenceModal"></view>
  <view class="evidence-modal" wx:if="{{showEvidenceModal}}">
    <view class="modal-header">
      <text class="modal-title">举证上传</text>
      <view class="modal-close" bindtap="onCloseEvidenceModal">×</view>
    </view>
    <view class="modal-body">
      <view class="form-item">
        <text class="form-label">举证说明</text>
        <textarea class="form-textarea" placeholder="请输入举证说明（选填）" value="{{evidenceDescription}}" bindinput="onEvidenceDescInput" maxlength="200" auto-height></textarea>
      </view>
      <view class="form-item">
        <text class="form-label">上传凭证文件</text>
        <view class="upload-tip">支持图片、文档，单文件不超过10M</view>
        <view class="upload-btn" bindtap="onChooseEvidenceFile">
          <text class="upload-icon">+</text>
          <text class="upload-text">选择文件</text>
        </view>
        <view class="evidence-file-list">
          <view class="evidence-file-item" wx:for="{{evidenceFileList}}" wx:key="index">
            <text class="file-name">{{item.name}}</text>
            <text class="file-size">{{item.size_text}}</text>
            <text class="file-delete" bindtap="onRemoveEvidenceFile" data-index="{{index}}">×</text>
          </view>
        </view>
      </view>
    </view>
    <view class="modal-footer">
      <view class="btn-cancel" bindtap="onCloseEvidenceModal">
        <text>取消</text>
      </view>
      <view class="btn-confirm" bindtap="onSubmitEvidence">
        <text>提交举证</text>
      </view>
    </view>
  </view>

  <!-- 飞单风控警告弹窗 -->
  <view class="modal-mask" wx:if="{{showAntiFraudModal}}" bindtap="onCloseAntiFraudModal"></view>
  <view class="anti-fraud-modal" wx:if="{{showAntiFraudModal}}">
    <view class="modal-icon">⚠️</view>
    <view class="modal-title">风险提示</view>
    <view class="modal-content">
      <text>{{antiFraudModalContent}}</text>
    </view>
    <view class="modal-btn" bindtap="onCloseAntiFraudModal">
      <text>我知道了</text>
    </view>
  </view>
</view>