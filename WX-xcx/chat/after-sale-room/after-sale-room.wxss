.after-sale-room-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

/* 顶部栏 */
.chat-header {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  height: 88rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #eeeeee;
  flex-shrink: 0;
}

.header-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: #333333;
  font-weight: 300;
}

.header-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
}

.header-order {
  font-size: 22rpx;
  color: #0f3460;
}

.header-more {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.more-icon {
  font-size: 36rpx;
  color: #666666;
  font-weight: bold;
}

/* 介入警示横幅 */
.intervene-banner {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: #e94560;
  flex-shrink: 0;
}

.intervene-banner-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.intervene-banner-text {
  font-size: 24rpx;
  color: #ffffff;
  line-height: 1.5;
  flex: 1;
}

/* 介入工具栏 */
.intervene-toolbar {
  display: flex;
  justify-content: center;
  padding: 16rpx 24rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #eeeeee;
  flex-shrink: 0;
}

.intervene-btn {
  padding: 14rpx 48rpx;
  background-color: #e94560;
  border-radius: 32rpx;
}

.intervene-btn-disabled {
  background-color: #cccccc;
}

.intervene-btn-text {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 500;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 20rpx 24rpx;
  overflow-y: auto;
}

.loading-history {
  text-align: center;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: #999999;
}

.no-more-history {
  text-align: center;
  padding: 20rpx 0;
  font-size: 22rpx;
  color: #cccccc;
}

/* 消息项 */
.message-item {
  display: flex;
  margin-bottom: 24rpx;
}

.message-self {
  flex-direction: row-reverse;
}

.message-other {
  flex-direction: row;
}

.system-message {
  width: 100%;
  text-align: center;
  padding: 10rpx 0;
}

.system-text {
  display: inline-block;
  padding: 6rpx 20rpx;
  font-size: 22rpx;
  color: #999999;
  background-color: rgba(0, 0, 0, 0.04);
  border-radius: 8rpx;
}

.msg-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
  flex-shrink: 0;
}

.message-self .msg-avatar {
  margin-left: 16rpx;
}

.message-other .msg-avatar {
  margin-right: 16rpx;
}

.msg-content-wrapper {
  max-width: 70%;
}

.msg-sender {
  display: flex;
  align-items: center;
  margin-bottom: 4rpx;
  padding-left: 8rpx;
}

.sender-name {
  font-size: 22rpx;
  color: #999999;
  margin-right: 8rpx;
}

/* V标 */
.v-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 6rpx;
}

.v-badge-text {
  font-size: 20rpx;
  font-weight: bold;
  border-radius: 4rpx;
  padding: 0 4rpx;
}

.v-badge-golden {
  background: linear-gradient(135deg, #f5af19, #f12711);
  color: #ffffff;
  font-size: 22rpx;
  padding: 2rpx 6rpx;
}

/* 平台官方标识 */
.platform-tag {
  font-size: 22rpx;
  color: #f5af19;
  font-weight: 500;
}

.msg-bubble {
  display: inline-block;
  border-radius: 16rpx;
  position: relative;
}

.bubble-self {
  background-color: #e94560;
  color: #ffffff;
  border-top-right-radius: 4rpx;
}

.bubble-other {
  background-color: #ffffff;
  color: #333333;
  border-top-left-radius: 4rpx;
}

.msg-text {
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-all;
}

.msg-image {
  padding: 0;
  overflow: hidden;
  background: transparent;
}

.msg-img {
  width: 320rpx;
  display: block;
  border-radius: 16rpx;
}

.msg-voice {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  min-width: 120rpx;
}

.voice-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.voice-duration {
  font-size: 26rpx;
}

.bubble-other .voice-icon {
  color: #333333;
}

.msg-recall {
  background-color: transparent;
  padding: 8rpx 16rpx;
}

.recall-text {
  font-size: 24rpx;
  color: #999999;
}

.sensitive-tip {
  margin-top: 8rpx;
  padding: 6rpx 12rpx;
  background-color: rgba(255, 151, 106, 0.1);
  border-radius: 8rpx;
}

.sensitive-tip text {
  font-size: 22rpx;
  color: #ff976a;
}

/* 底部输入栏 */
.input-bar {
  background-color: #ffffff;
  border-top: 1rpx solid #eeeeee;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}

.text-mode {
  display: flex;
  align-items: center;
}

.mode-switch {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.switch-icon {
  font-size: 32rpx;
}

.input-wrapper {
  flex: 1;
  background-color: #f5f5f5;
  border-radius: 32rpx;
  padding: 0 24rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
}

.text-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #333333;
}

.input-placeholder {
  color: #cccccc;
}

.image-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.image-icon {
  font-size: 32rpx;
}

.send-btn {
  padding: 0 24rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #e94560;
  border-radius: 28rpx;
  margin-top: 12rpx;
  align-self: flex-end;
}

.send-text {
  font-size: 26rpx;
  color: #ffffff;
}

.voice-mode {
  display: flex;
  justify-content: center;
  padding: 8rpx 0;
}

.voice-btn {
  width: 360rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  border-radius: 36rpx;
  border: 2rpx solid #eeeeee;
}

.voice-btn-text {
  font-size: 28rpx;
  color: #666666;
}

.voice-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.voice-overlay-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.voice-wave {
  display: flex;
  align-items: flex-end;
  height: 80rpx;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.wave-bar {
  width: 8rpx;
  background-color: #ffffff;
  border-radius: 4rpx;
  animation: wave 0.8s ease-in-out infinite;
  height: 40rpx;
}

@keyframes wave {
  0%, 100% { height: 20rpx; }
  50% { height: 80rpx; }
}

.voice-overlay-tip {
  font-size: 28rpx;
  color: #ffffff;
  padding: 12rpx 32rpx;
  background-color: rgba(0, 0, 0, 0.3);
  border-radius: 8rpx;
}

.voice-overlay-tip.cancel-tip {
  color: #e94560;
  background-color: rgba(233, 69, 96, 0.2);
}

/* 更多面板 */
.more-panel {
  display: flex;
  justify-content: space-around;
  padding: 32rpx 0;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  border-top: 1rpx solid #eeeeee;
}

.panel-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.panel-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.panel-label {
  font-size: 22rpx;
  color: #666666;
}