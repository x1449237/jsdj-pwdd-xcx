.group-list-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 搜索栏 */
.search-bar {
  padding: 16rpx 24rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f5f5f5;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 32rpx;
  padding: 0 20rpx;
  height: 64rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 26rpx;
  color: #333333;
}

.placeholder {
  color: #cccccc;
}

/* 群聊列表 */
.group-list {
  background-color: #ffffff;
}

.group-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background-color 0.2s;
}

.group-item:active {
  background-color: #f9f9f9;
}

.avatar-wrapper {
  position: relative;
  margin-right: 20rpx;
}

.group-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  background-color: #f5f5f5;
}

.unread-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 36rpx;
  height: 36rpx;
  background-color: #e94560;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.unread-badge text {
  font-size: 20rpx;
  color: #ffffff;
}

.group-info {
  flex: 1;
  min-width: 0;
}

.info-header {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.group-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin-right: 12rpx;
  max-width: 280rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.group-type-tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.group-type-chat {
  background-color: rgba(233, 69, 96, 0.1);
  color: #e94560;
}

.group-type-welfare {
  background-color: rgba(7, 193, 96, 0.1);
  color: #07c160;
}

.group-type-after_sale {
  background-color: rgba(15, 52, 96, 0.1);
  color: #0f3460;
}

.time {
  font-size: 22rpx;
  color: #cccccc;
  flex-shrink: 0;
  margin-left: auto;
}

.info-footer {
  display: flex;
  align-items: center;
}

.last-message {
  font-size: 26rpx;
  color: #999999;
  flex: 1;
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-state-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-state-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.empty-state-sub {
  font-size: 24rpx;
  color: #cccccc;
}

.loading-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.loading-more {
  text-align: center;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: #999999;
}

/* 创建按钮 */
.create-btn-wrapper {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
}

.create-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, #e94560, #d63851);
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(233, 69, 96, 0.35);
}

.create-btn-icon {
  font-size: 36rpx;
  color: #ffffff;
  margin-right: 12rpx;
  font-weight: 300;
}

.create-btn-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
}

/* 创建弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.create-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  z-index: 101;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999999;
}

.modal-body {
  padding: 32rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.form-placeholder {
  color: #cccccc;
}

.type-selector {
  display: flex;
  gap: 16rpx;
}

.type-option {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666666;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.type-option-active {
  background-color: rgba(233, 69, 96, 0.08);
  color: #e94560;
  border-color: #e94560;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f5f5f5;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.btn-cancel {
  color: #999999;
  border-right: 1rpx solid #f5f5f5;
}

.btn-confirm {
  color: #e94560;
  font-weight: 600;
}