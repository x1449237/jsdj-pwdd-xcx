.after-sale-list-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 搜索栏 */
.search-bar {
  padding: 16rpx 24rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f5f5f5;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 32rpx;
  padding: 0 20rpx;
  height: 64rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 26rpx;
  color: #333333;
}

.placeholder {
  color: #cccccc;
}

/* 会话列表 */
.session-list {
  background-color: #ffffff;
}

.session-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background-color 0.2s;
}

.session-item:active {
  background-color: #f9f9f9;
}

.avatar-wrapper {
  position: relative;
  margin-right: 20rpx;
}

.session-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
}

.unread-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 36rpx;
  height: 36rpx;
  background-color: #e94560;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.unread-badge text {
  font-size: 20rpx;
  color: #ffffff;
}

.session-info {
  flex: 1;
  min-width: 0;
}

.info-header {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.session-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin-right: 12rpx;
  max-width: 260rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.intervene-tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.intervene-none {
  background-color: rgba(153, 153, 153, 0.1);
  color: #999999;
}

.intervene-ing {
  background-color: rgba(233, 69, 96, 0.1);
  color: #e94560;
}

.intervene-done {
  background-color: rgba(7, 193, 96, 0.1);
  color: #07c160;
}

.time {
  font-size: 22rpx;
  color: #cccccc;
  flex-shrink: 0;
  margin-left: auto;
}

.info-footer {
  display: flex;
  flex-direction: column;
}

.order-sn {
  font-size: 24rpx;
  color: #0f3460;
  margin-bottom: 4rpx;
}

.last-message {
  font-size: 26rpx;
  color: #999999;
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-state-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-state-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.empty-state-sub {
  font-size: 24rpx;
  color: #cccccc;
}

.loading-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.loading-more {
  text-align: center;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: #999999;
}

/* 创建按钮 */
.create-btn-wrapper {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
}

.create-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, #0f3460, #1a4a80);
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 52, 96, 0.35);
}

.create-btn-icon {
  font-size: 36rpx;
  color: #ffffff;
  margin-right: 12rpx;
  font-weight: 300;
}

.create-btn-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.create-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 640rpx;
  max-height: 80vh;
  background-color: #ffffff;
  border-radius: 24rpx;
  z-index: 101;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  flex-shrink: 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999999;
}

.modal-body {
  padding: 32rpx;
  overflow-y: auto;
  flex: 1;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.order-selector {
  max-height: 240rpx;
  overflow-y: auto;
  background-color: #f5f5f5;
  border-radius: 12rpx;
}

.order-option {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #eeeeee;
  transition: background-color 0.2s;
}

.order-option:last-child {
  border-bottom: none;
}

.order-option-active {
  background-color: rgba(15, 52, 96, 0.08);
  color: #0f3460;
}

.order-sn-text {
  font-size: 26rpx;
  color: #333333;
}

.order-option-active .order-sn-text {
  color: #0f3460;
}

.order-amount {
  font-size: 24rpx;
  color: #e94560;
}

.order-empty {
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #cccccc;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.form-placeholder {
  color: #cccccc;
}

.image-uploader {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-preview {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  position: relative;
  overflow: hidden;
}

.preview-img {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.image-remove {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 36rpx;
  height: 36rpx;
  background-color: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #ffffff;
}

.image-add {
  width: 140rpx;
  height: 140rpx;
  border: 2rpx dashed #dddddd;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #fafafa;
}

.add-icon {
  font-size: 48rpx;
  color: #cccccc;
  line-height: 1;
}

.add-text {
  font-size: 20rpx;
  color: #cccccc;
  margin-top: 4rpx;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f5f5f5;
  flex-shrink: 0;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.btn-cancel {
  color: #999999;
  border-right: 1rpx solid #f5f5f5;
}

.btn-confirm {
  color: #0f3460;
  font-weight: 600;
}