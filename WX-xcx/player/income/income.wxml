<!-- 收益中心 -->
<view class="page-income">
  <!-- 余额卡片 -->
  <view class="balance-card bg-dark">
    <view class="balance-header flex-between">
      <text class="balance-title text-white">我的收益</text>
      <view class="balance-tip flex align-center" bindtap="showWithdrawRule">
        <text class="text-tip text-xs">提现规则</text>
        <text class="text-tip text-xs ml-sm">></text>
      </view>
    </view>
    <view class="balance-amounts flex">
      <view class="balance-item flex-1">
        <text class="balance-label text-tip">可用余额（元）</text>
        <view class="balance-value-row flex align-center">
          <text class="balance-symbol text-white">¥</text>
          <text class="balance-value text-white text-xxl font-bold">{{availableBalance}}</text>
        </view>
      </view>
      <view class="balance-divider"></view>
      <view class="balance-item flex-1 pl-lg">
        <text class="balance-label text-tip">冻结金额（元）</text>
        <view class="balance-value-row flex align-center">
          <text class="balance-symbol text-tip">¥</text>
          <text class="balance-value text-tip text-xxl font-bold">{{frozenBalance}}</text>
        </view>
        <text class="balance-hint text-xs text-tip">T+3 自动解冻</text>
      </view>
    </view>
    <button class="btn btn-primary btn-block withdraw-btn mt-lg" bindtap="goWithdraw">
      立即提现
    </button>
  </view>

  <!-- 收入明细 -->
  <view class="income-section">
    <view class="section-header flex-between p-md bg-white">
      <text class="section-title text-lg font-bold">收入明细</text>
      <picker mode="selector" range="{{monthFilter}}" bindchange="onMonthChange" value="{{monthIndex}}">
        <view class="month-picker flex align-center">
          <text class="text-secondary">{{selectedMonth || '全部月份'}}</text>
          <text class="text-tip ml-sm">▼</text>
        </view>
      </picker>
    </view>

    <view class="income-list" wx:if="{{incomeList.length > 0}}">
      <block wx:for="{{incomeList}}" wx:key="month">
        <!-- 月份分组标题 -->
        <view class="month-divider">
          <text class="month-text">{{item.month}}</text>
          <text class="month-total text-primary">¥{{item.monthTotal}}</text>
        </view>

        <!-- 收入明细项 -->
        <view class="income-item card" wx:for="{{item.items}}" wx:for-item="income" wx:key="id">
          <view class="income-header flex-between">
            <view class="flex align-center">
              <view class="income-type-icon {{income.typeClass}}">
                <text class="iconfont">{{income.typeIcon}}</text>
              </view>
              <view>
                <text class="income-type text-md">{{income.typeText}}</text>
                <text class="income-order text-xs text-tip ml-sm">{{income.orderNo}}</text>
              </view>
            </view>
            <text class="income-amount text-lg font-bold {{income.amount >= 0 ? 'text-success' : 'text-danger'}}">
              {{income.amount >= 0 ? '+' : ''}}¥{{income.amountText}}
            </text>
          </view>
          <view class="income-footer flex-between mt-sm">
            <text class="income-time text-xs text-tip">{{income.timeText}}</text>
            <text class="income-status text-xs" wx:if="{{income.statusText}}">{{income.statusText}}</text>
          </view>
        </view>
      </block>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && incomeList.length === 0}}">
      <image class="empty-state-image" src="/assets/images/empty-income.png" mode="aspectFit" />
      <text class="empty-state-text">暂无收入记录</text>
    </view>

    <!-- 加载更多 -->
    <view class="loading-more" wx:if="{{loadingMore}}">
      <text>加载中...</text>
    </view>
    <view class="no-more" wx:if="{{!hasMore && incomeList.length > 0}}">
      <text>—— 没有更多了 ——</text>
    </view>
  </view>
</view>

<!-- 提现规则说明弹窗 -->
<view class="modal-mask" wx:if="{{showRuleModal}}" bindtap="closeRuleModal">
  <view class="modal-dialog" catchtap="noop">
    <view class="modal-title text-lg font-bold">提现规则说明</view>
    <view class="modal-body">
      <view class="rule-item">
        <text class="rule-label">1. 冻结说明</text>
        <text class="rule-desc">订单完成后，资金将冻结 T+3 个自然日，期间无法提现。3天后自动解冻至可用余额。</text>
      </view>
      <view class="rule-item">
        <text class="rule-label">2. 提现时间</text>
        <text class="rule-desc">每日 8:00-22:00 可申请提现，到账时间视银行处理速度，通常为 2 小时内。</text>
      </view>
      <view class="rule-item">
        <text class="rule-label">3. 提现限额</text>
        <text class="rule-desc">单笔最低提现金额 ¥1.00，单日最高提现 ¥5,000.00。</text>
      </view>
      <view class="rule-item">
        <text class="rule-label">4. 手续费</text>
        <text class="rule-desc">提现免手续费。</text>
      </view>
    </view>
    <view class="modal-footer">
      <button class="btn btn-sm btn-primary btn-block" bindtap="closeRuleModal">我知道了</button>
    </view>
  </view>
</view>