<!-- 接单中心 -->
<view class="page-order-center">
  <!-- WebSocket 连接状态指示 -->
  <view class="ws-status {{wsConnected ? 'ws-connected' : 'ws-disconnected'}}">
    <view class="ws-dot"></view>
    <text class="ws-text">{{wsConnected ? '已连接实时推送' : '连接断开，请检查网络'}}</text>
    <view class="ws-retry" wx:if="{{!wsConnected}}" bindtap="reconnectWs">重连</view>
  </view>

  <!-- 新订单推送通知条 -->
  <view class="new-order-notice {{showNewOrderNotice ? 'notice-show' : ''}}" wx:if="{{showNewOrderNotice}}" bindtap="scrollToTop">
    <view class="notice-icon">
      <text class="iconfont icon-bell"></text>
    </view>
    <view class="notice-content">
      <text class="notice-title">您有 {{newOrderCount}} 个新订单待接</text>
      <text class="notice-desc">点击查看最新订单</text>
    </view>
    <view class="notice-close" catchtap="closeNewOrderNotice">
      <text class="iconfont icon-close"></text>
    </view>
  </view>

  <!-- 订单列表 -->
  <scroll-view
    class="order-scroll"
    scroll-y
    refresher-enabled
    refresher-triggered="{{isRefreshing}}"
    refresher-threshold="{{100}}"
    bindrefresherrefresh="onRefresh"
    bindscrolltolower="onLoadMore"
    lower-threshold="100"
  >
    <view class="order-list" wx:if="{{orderList.length > 0}}">
      <view class="order-card card shadow-sm" wx:for="{{orderList}}" wx:key="orderId">
        <!-- 订单头部 -->
        <view class="order-header flex-between">
          <view class="order-game-info flex align-center">
            <image class="game-icon" src="{{item.gameIcon}}" mode="aspectFill" />
            <view class="game-text">
              <text class="game-name text-lg font-bold">{{item.gameName}}</text>
              <text class="service-type tag tag-primary ml-sm">{{item.serviceTypeText}}</text>
            </view>
          </view>
          <view class="order-amount">
            <text class="amount-symbol">¥</text>
            <text class="amount-value text-xl font-bold text-primary">{{item.amountText}}</text>
          </view>
        </view>

        <!-- 订单详情 -->
        <view class="order-body">
          <view class="order-info-row flex-between">
            <text class="info-label text-secondary">服务要求</text>
            <text class="info-value text-ellipsis">{{item.serviceDesc || '无特殊要求'}}</text>
          </view>
          <view class="order-info-row flex-between">
            <text class="info-label text-secondary">玩家信息</text>
            <view class="player-info flex align-center">
              <image class="player-avatar" src="{{item.playerAvatar}}" mode="aspectFill" />
              <text class="player-name text-secondary">{{item.playerName}}</text>
              <text class="player-level tag tag-warning" wx:if="{{item.playerLevel}}">{{item.playerLevel}}</text>
            </view>
          </view>
          <view class="order-info-row flex-between">
            <text class="info-label text-secondary">发布时间</text>
            <text class="info-value text-tip">{{item.publishTimeText}}</text>
          </view>
          <view class="order-info-row flex-between" wx:if="{{item.timeLimit}}">
            <text class="info-label text-secondary">时限要求</text>
            <text class="info-value text-warning">{{item.timeLimit}}</text>
          </view>
        </view>

        <!-- 操作按钮 -->
        <view class="order-actions flex-between">
          <view class="action-left">
            <text class="free-count text-tip" wx:if="{{item.freeCancelCount > 0}}">
              今日剩余免罚次数：{{item.freeCancelCount}}
            </text>
          </view>
          <view class="action-right flex">
            <!-- 确认接单中（倒计时） -->
            <block wx:if="{{item.isConfirming}}">
              <view class="countdown-tip text-warning">
                <text class="countdown-icon">⏳</text>
                <text>{{item.confirmCountdown}} 秒后自动确认</text>
              </view>
              <button class="btn btn-sm btn-primary ml-sm" bindtap="confirmAccept" data-order-id="{{item.orderId}}">
                确认接单
              </button>
              <button class="btn btn-sm btn-ghost ml-sm" bindtap="cancelAccept" data-order-id="{{item.orderId}}">
                取消
              </button>
            </block>
            <!-- 正常操作 -->
            <block wx:else>
              <button class="btn btn-sm btn-outline btn-reject" bindtap="rejectOrder" data-order-id="{{item.orderId}}" data-free-count="{{item.freeCancelCount}}">
                拒单
              </button>
              <button class="btn btn-sm btn-primary ml-sm" bindtap="acceptOrder" data-order-id="{{item.orderId}}">
                接单
              </button>
            </block>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && orderList.length === 0}}">
      <image class="empty-state-image" src="/assets/images/empty-order.png" mode="aspectFit" />
      <text class="empty-state-text">暂时没有待接订单</text>
      <text class="empty-state-sub text-tip mt-sm">下拉刷新试试</text>
    </view>

    <!-- 加载更多 -->
    <view class="loading-more" wx:if="{{loadingMore}}">
      <text>加载中...</text>
    </view>
    <view class="no-more" wx:if="{{!hasMore && orderList.length > 0}}">
      <text>—— 没有更多了 ——</text>
    </view>
  </scroll-view>
</view>

<!-- 拒单确认弹窗 -->
<view class="modal-mask" wx:if="{{showRejectModal}}" bindtap="closeRejectModal">
  <view class="modal-dialog" catchtap="noop">
    <view class="modal-title text-lg font-bold">确认拒单</view>
    <view class="modal-body">
      <text class="text-md">确定要拒绝该订单吗？</text>
      <view class="reject-info mt-md">
        <view class="flex-between" wx:if="{{rejectOrderInfo.freeCancelCount > 0}}">
          <text class="text-secondary">今日剩余免罚次数</text>
          <text class="text-success">{{rejectOrderInfo.freeCancelCount}} 次</text>
        </view>
        <view class="flex-between" wx:if="{{rejectOrderInfo.freeCancelCount === 0}}">
          <text class="text-secondary">免罚次数已用完</text>
          <text class="text-danger">本次拒单将被记录处罚</text>
        </view>
      </view>
    </view>
    <view class="modal-footer flex">
      <button class="btn btn-sm btn-ghost flex-1" bindtap="closeRejectModal">再想想</button>
      <button class="btn btn-sm btn-danger flex-1 ml-sm" bindtap="confirmReject">确认拒单</button>
    </view>
  </view>
</view>