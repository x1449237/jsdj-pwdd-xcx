/* 下级管理 */
.page-subordinates {
  min-height: 100vh;
  background-color: var(--color-bg);
  display: flex;
  flex-direction: column;
}

/* ========== 搜索栏 ========== */
.search-bar {
  border-bottom: 1rpx solid var(--color-border);
}

.search-input-wrapper {
  height: 64rpx;
  background-color: var(--color-bg);
  border-radius: 32rpx;
  padding: 0 var(--spacing-sm);
}

.search-icon {
  font-size: var(--font-size-sm);
  margin-right: 8rpx;
  flex-shrink: 0;
}

.search-input {
  height: 64rpx;
  font-size: var(--font-size-sm);
}

.search-clear {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: var(--color-border);
  font-size: 20rpx;
  flex-shrink: 0;
}

/* ========== Tab 切换 ========== */
.tab-bar {
  border-bottom: 1rpx solid var(--color-border);
}

.tab-item {
  height: 80rpx;
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  position: relative;
}

.tab-active {
  color: var(--color-primary);
  font-weight: bold;
}

.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background-color: var(--color-primary);
  border-radius: 2rpx;
}

.tab-count {
  font-size: var(--font-size-xs);
  padding: 2rpx 10rpx;
  background-color: rgba(233, 69, 96, 0.1);
  border-radius: 16rpx;
  color: var(--color-primary);
}

/* ========== 下级列表 ========== */
.sub-scroll {
  flex: 1;
  height: 0;
}

.sub-list {
  padding: var(--spacing-sm) var(--spacing-md);
}

.sub-card {
  margin-bottom: var(--spacing-sm);
}

.sub-header {
  padding-bottom: var(--spacing-sm);
  border-bottom: 1rpx solid var(--color-border);
}

.sub-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: var(--spacing-sm);
  flex-shrink: 0;
}

.sub-user-info {
  flex: 1;
}

.sub-name {
  display: block;
}

.sub-parent {
  max-width: 200rpx;
}

.sub-body {
  padding-top: var(--spacing-xs);
}

.sub-info-item {
  display: flex;
  flex-direction: column;
}

.sub-info-item .info-label {
  margin-bottom: 4rpx;
}

/* ========== 空状态 ========== */
.empty-state-sub {
  font-size: var(--font-size-sm);
}